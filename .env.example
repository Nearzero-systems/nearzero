# Primary database. The self-host installer generates this for local Postgres.
DATABASE_URL=postgresql://nearzero:nearzero-local-password@postgres:5432/nearzero

# Local Postgres settings for docker-compose.local-db.yml.
POSTGRES_USER=nearzero
POSTGRES_PASSWORD=nearzero-local-password
POSTGRES_DB=nearzero

PORT=3000
HOST=0.0.0.0
NODE_ENV=production

BETTER_AUTH_URL=http://localhost:4321
BETTER_AUTH_SECRET=change-me-use-openssl-rand-base64-32
CONSOLE_URL=http://localhost:4321

BACKEND_URL=http://platform:3000
PUBLIC_BACKEND_URL=http://localhost:3000
PUBLIC_GIT_PROVIDER_BASE_URL=http://localhost:4321

# Comma-separated browser origins allowed for auth (installer auto-detects public IP).
# NEARZERO_TRUSTED_ORIGINS=http://your-host:4321,http://your-host:3000

REDIS_URL=redis://redis:6379

# Optional platform apex for automatic service URLs (Mode B).
# NEARZERO_PLATFORM_DOMAIN=your-domain.example.com

# Optional schedules service for distributed backup and maintenance jobs.
# JOBS_URL=http://schedules:4001
# API_KEY=change-me-shared-schedules-api-key

# Auth uses email + password (no third-party email provider required).
# Configure Agent BYOK and notification providers in the dashboard after install.
