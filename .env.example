# Primary database. The self-host installer generates this for local Postgres.
DATABASE_URL=postgresql://nearzero:nearzero-local-password@postgres:5432/nearzero

# Local Postgres settings for docker-compose.local-db.yml.
POSTGRES_USER=nearzero
POSTGRES_PASSWORD=nearzero-local-password
POSTGRES_DB=nearzero

PORT=3000
HOST=0.0.0.0
NODE_ENV=production

BETTER_AUTH_URL=http://localhost:4321
BETTER_AUTH_SECRET=change-me-use-openssl-rand-base64-32
CONSOLE_URL=http://localhost:4321

BACKEND_URL=http://platform:3000
PUBLIC_BACKEND_URL=http://localhost:3000
PUBLIC_GIT_PROVIDER_BASE_URL=http://localhost:4321

# Optional trusted self-hosted template registry. Browser requests cannot
# override this allowlisted origin.
# NEARZERO_TEMPLATE_BASE_URL=https://templates.example.com

# Comma-separated browser origins allowed for auth (installer auto-detects public IP).
# NEARZERO_TRUSTED_ORIGINS=http://your-host:4321,http://your-host:3000

REDIS_URL=redis://redis:6379

# Start the authoritative CoreDNS service in docker-compose.prod.yml.
# Set this to an empty value if this host must not publish DNS on port 53.
COMPOSE_PROFILES=managed-dns
NEARZERO_ENABLE_MANAGED_DNS=true
NEARZERO_DNS_IMAGE=coredns/coredns:1.14.6
NEARZERO_DNS_BIND_ADDRESS=0.0.0.0
NEARZERO_DNS_PORT=53

# Remote-server ingress images. Exact tags are safe defaults; for production,
# replace these with registry digest references you have verified.
# TRAEFIK_IMAGE=traefik@sha256:replace-with-verified-digest
# TRAEFIK_SOCKET_PROXY_IMAGE=ghcr.io/tecnativa/docker-socket-proxy@sha256:replace-with-verified-digest

# Optional immutable managed-build images. When set, these must be
# complete OCI references pinned by sha256 digest; mutable tags are rejected.
# NEARZERO_HEROKU_BUILDER_IMAGE=registry.example.com/heroku-builder:24@sha256:replace-with-verified-digest
# NEARZERO_PAKETO_BUILDER_IMAGE=registry.example.com/paketo-builder:jammy@sha256:replace-with-verified-digest
# NEARZERO_RAILPACK_FRONTEND_IMAGE=ghcr.io/railwayapp/railpack-frontend:v0.15.4@sha256:replace-with-verified-digest
# NEARZERO_STATIC_NGINX_IMAGE=nginx@sha256:replace-with-verified-digest

# Unknown remote SSH host keys use trust on first use unless strict mode is
# enabled. Seed the protected host-key store before enabling strict mode.
NEARZERO_SSH_STRICT_HOST_KEY_CHECKING=false

# Release-matched runtime images. Production operators can replace tags with
# registry digests after verifying the multi-architecture manifests they use.
NEARZERO_IMAGE=ghcr.io/nearzero-systems/nearzero:0.1.40
NEARZERO_MONITORING_IMAGE=ghcr.io/nearzero-systems/monitoring:0.1.40
NEARZERO_SCHEDULE_IMAGE=ghcr.io/nearzero-systems/schedule:0.1.40

# Container metrics are fail-closed. Enabling this lets the monitoring
# collector use Docker's read-only CONTAINERS API, which can expose inspect
# metadata including container environment variables. Leave false unless that
# disclosure is explicitly acceptable and services are intentionally included.
NEARZERO_ALLOW_MONITORING_DOCKER_METADATA=false

# Optional platform apex for automatic service URLs (Mode B). This mode expects
# an external wildcard DNS/edge route; it does not create per-server DNS records.
# NEARZERO_PLATFORM_DOMAIN=your-domain.example.com
# Set only when that shared edge can route each hostname to its selected remote
# server. Otherwise remote apps fall back until an environment binds a DNS zone.
# NEARZERO_PLATFORM_DOMAIN_SHARED_EDGE=false

# Optional schedules service for distributed backup and maintenance jobs.
# JOBS_URL=http://schedules:4001
# API_KEY=change-me-shared-schedules-api-key

# Auth uses email + password (no third-party email provider required).
# Configure Agent BYOK and notification providers in the dashboard after install.
