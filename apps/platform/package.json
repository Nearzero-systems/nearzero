{
  "name": "@nearzero/platform",
  "version": "0.0.1",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "bun run build:deps && bun run build-server",
    "build:deps": "bun run --filter @nearzero/server build && bun run --filter @nearzero/agent build && bun run --filter @nearzero/trpc-openapi build",
    "start": "node -r dotenv/config dist/migration.mjs && node -r dotenv/config dist/server.mjs",
    "build-server": "bun esbuild.config.ts",
    "setup": "tsx -r dotenv/config setup.ts && sleep 5 && bun run migration:run",
    "wait-for-postgres": "node -r dotenv/config dist/wait-for-postgres.mjs",
    "wait-for-postgres-dev": "tsx -r dotenv/config wait-for-postgres.ts",
    "reset-2fa": "node -r dotenv/config dist/reset-2fa.mjs",
    "migrate-auth-secret": "node -r dotenv/config dist/migrate-auth-secret.mjs",
    "dev": "bun run --filter @nearzero/server switch:dev && tsx watch -r dotenv/config ./server/server.ts --project tsconfig.server.json",
    "studio": "drizzle-kit studio --config ./server/db/drizzle.config.ts",
    "migration:generate": "drizzle-kit generate --config ./server/db/drizzle.config.ts",
    "migration:run": "tsx -r dotenv/config migration.ts",
    "migration:up": "drizzle-kit up --config ./server/db/drizzle.config.ts",
    "migration:drop": "drizzle-kit drop --config ./server/db/drizzle.config.ts",
    "db:push": "drizzle-kit push --config ./server/db/drizzle.config.ts",
    "db:truncate": "tsx -r dotenv/config ./server/db/reset.ts",
    "db:studio": "drizzle-kit studio --config ./server/db/drizzle.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.server.json",
    "test": "vitest --config __test__/vitest.config.ts",
    "generate:openapi": "tsx -r dotenv/config scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@better-auth/api-key": "1.5.4",
    "@better-auth/sso": "1.5.4",
    "@better-auth/utils": "0.3.1",
    "@faker-js/faker": "^8.4.1",
    "@nearzero/agent": "workspace:*",
    "@nearzero/edition-community": "workspace:*",
    "@nearzero/edition-contract": "workspace:*",
    "@nearzero/server": "workspace:*",
    "@nearzero/trpc-openapi": "workspace:*",
    "@octokit/auth-app": "^6.1.3",
    "@octokit/rest": "^20.1.2",
    "@octokit/webhooks": "^13.9.0",
    "@oslojs/crypto": "1.0.1",
    "@oslojs/encoding": "1.1.0",
    "@react-email/components": "^0.0.21",
    "@trpc/server": "^11.10.0",
    "adm-zip": "^0.5.16",
    "bcrypt": "5.1.1",
    "better-auth": "1.5.4",
    "better-call": "2.0.2",
    "bl": "6.0.11",
    "boxen": "^7.1.1",
    "bullmq": "5.67.3",
    "date-fns": "3.6.0",
    "dockerode": "4.0.2",
    "dotenv": "16.4.5",
    "drizzle-dbml-generator": "0.10.0",
    "drizzle-orm": "0.45.1",
    "drizzle-zod": "0.8.3",
    "fancy-ansi": "^0.1.3",
    "lodash": "4.17.21",
    "micromatch": "4.0.8",
    "nanoid": "3.3.11",
    "node-os-utils": "2.0.1",
    "node-pty": "1.1.0",
    "node-schedule": "2.1.1",
    "nodemailer": "6.9.14",
    "octokit": "3.1.2",
    "pino": "9.4.0",
    "pino-pretty": "11.2.2",
    "postgres": "3.4.4",
    "public-ip": "6.0.2",
    "qrcode": "^1.5.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "resend": "^6.0.2",
    "semver": "7.7.3",
    "shell-quote": "^1.8.1",
    "slugify": "^1.6.6",
    "ssh2": "~1.16.0",
    "superjson": "^2.2.2",
    "toml": "3.0.0",
    "undici": "^6.21.3",
    "ws": "8.16.0",
    "yaml": "2.8.1",
    "zod": "^4.3.6",
    "zod-form-data": "^3.0.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/bcrypt": "5.0.2",
    "@types/lodash": "4.17.4",
    "@types/micromatch": "4.0.9",
    "@types/node": "^24.4.0",
    "@types/node-schedule": "2.1.6",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/semver": "7.7.1",
    "@types/shell-quote": "^1.7.5",
    "@types/ssh2": "1.15.1",
    "@types/ws": "8.5.10",
    "drizzle-kit": "^0.31.4",
    "esbuild": "0.20.2",
    "lint-staged": "^15.5.2",
    "memfs": "^4.17.2",
    "simple-icons": "^16.14.0",
    "tsx": "^4.16.2",
    "typescript": "^5.8.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": "^24.4.0",
    "bun": ">=1.1.0"
  }
}
