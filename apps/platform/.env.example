# Local development database started by the Nearzero setup scripts.
DATABASE_URL="postgres://nearzero:nearzero-local-password@localhost:5432/nearzero"
# Production/Neon example:
# DATABASE_URL="postgresql://USER:PASSWORD@ep-example.region.aws.neon.tech/DB?sslmode=require"
# Required — BullMQ deployment queue. Use your hosted Redis URL in every environment.
# Local dev (optional): redis://USER:PASSWORD@127.0.0.1:6379  (%40 = @ in password)
# Production / cloud control-plane: Upstash or other remote Redis (prefer rediss:// TLS).
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST.upstash.io:6379
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Optional platform apex for automatic service URLs on deploy (Mode B).
# NEARZERO_PLATFORM_DOMAIN=nearzero.dev

# Required for auth cookies (console BFF proxies to platform)
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me-use-openssl-rand-base64-32-for-local-dev
# Required in production for all authentication and transactional email links.
CONSOLE_URL=http://localhost:4321
# Production split deploy example:
# NODE_ENV=production
# CONSOLE_URL=https://app.nearzero.dev
# BETTER_AUTH_URL=https://api.nearzero.dev
# Public HTTPS URL used in Git provider OAuth callbacks and GitHub App webhooks.
# Localhost will not work for GitHub App manifests; use a tunnel or deployed domain.
PUBLIC_GIT_PROVIDER_BASE_URL=https://your-public-nearzero-url.example.com

# Optional schedules service for distributed backup and maintenance jobs.
# JOBS_URL=http://127.0.0.1:4001
# API_KEY=change-me-shared-schedules-api-key

# Auth uses email OTP codes printed to server logs (docker logs).
# Optional SMTP for deployment/invitation notifications (Settings → Notifications).

# Agent / OpenRouter
# OPENROUTER_API_KEY — optional operator override; when set, org keys are ignored
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL — OpenRouter API base (default: https://openrouter.ai/api/v1)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER — sent as HTTP-Referer header to OpenRouter
OPENROUTER_HTTP_REFERER=http://localhost:4321
# OPENROUTER_X_TITLE — sent as X-Title header to OpenRouter
OPENROUTER_X_TITLE=Nearzero
# OPENROUTER_CHAT_MODEL — primary chat model for agent turns
OPENROUTER_CHAT_MODEL=moonshotai/kimi-k2.6
# OPENROUTER_TITLE_MODEL — model used to auto-name new threads
OPENROUTER_TITLE_MODEL=openai/gpt-4o-mini
# OPENROUTER_FOLLOWUPS_MODEL — model used for follow-up suggestion chips
OPENROUTER_FOLLOWUPS_MODEL=openai/gpt-4o-mini
# NEARZERO_AGENT_ENABLED — set false to disable agent routes and streaming
NEARZERO_AGENT_ENABLED=true
# NEARZERO_AGENT_SYSTEM_PROMPT — system prompt for every chat completion
NEARZERO_AGENT_SYSTEM_PROMPT="You are Nearzero Agent, a deployment copilot for projects, Docker, logs, and infrastructure."
# NEARZERO_AGENT_GREETING_TITLE — dashboard greeting; {firstName} is replaced
NEARZERO_AGENT_GREETING_TITLE="{firstName}, what do you want to deploy next?"
# NEARZERO_AGENT_GREETING_SUBTITLE — subtitle shown on empty agent home
NEARZERO_AGENT_GREETING_SUBTITLE="Your deployment assistant for projects, logs, and infrastructure."
# NEARZERO_AGENT_ONBOARDING_GREETING_ADMIN — streamed when no key and user is org admin
NEARZERO_AGENT_ONBOARDING_GREETING_ADMIN="Hi, I'm Nearzero Agent. I can help you with deployments, Docker, logs, and infrastructure.\n\nTo get started, add your organization's OpenRouter API key."
# NEARZERO_AGENT_ONBOARDING_GREETING_MEMBER — streamed when no key and user is not admin
NEARZERO_AGENT_ONBOARDING_GREETING_MEMBER="Hi, I'm Nearzero Agent. I can help you with deployments, Docker, logs, and infrastructure.\n\nTo get started, ask your organization admin to configure an OpenRouter API key in Settings → Agent."
# NEARZERO_AGENT_MAX_TURNS — max tool/LLM turns per user message
NEARZERO_AGENT_MAX_TURNS=12
# NEARZERO_AGENT_DEEP_RESEARCH_MAX_TURNS — max turns when deep research is requested
NEARZERO_AGENT_DEEP_RESEARCH_MAX_TURNS=48
# NEARZERO_AGENT_ATTACHMENTS_PATH — on-disk storage for uploaded agent files
NEARZERO_AGENT_ATTACHMENTS_PATH=/etc/nearzero/agent-attachments
# TAVILY_API_KEY — enables web search / deep research tool
TAVILY_API_KEY=
