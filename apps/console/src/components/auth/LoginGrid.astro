---
import AuthGrid from "./AuthGrid.astro";
import AuthButtonSpinner from "./AuthButtonSpinner.astro";
import {
	authBtnClass,
	authControlClass,
	authMutedText,
} from "@/lib/auth-form-classes";

interface Props {
	callbackUrl: string;
	registerHref?: string;
	initialEmail?: string;
}

const {
	callbackUrl,
	registerHref = "/register",
	initialEmail = "",
} = Astro.props;
---

<div
	id="nz-login-root"
	class="contents"
	data-callback-url={callbackUrl}
	data-register-href={registerHref}
	data-initial-email={initialEmail}
>
	<AuthGrid expandFormTile>
		<div slot="c4" class="mx-auto flex h-full w-full max-w-[30rem] items-end justify-center pb-1 text-center">
			<h1 class="font-display text-2xl font-semibold tracking-tight text-[#111827] sm:text-3xl">Welcome to Nearzero</h1>
		</div>
		<div slot="c7" class="mx-auto flex h-full w-full max-w-[30rem] items-center justify-center px-3 text-center">
			<p class={`text-sm ${authMutedText}`}>
				Don't have an account?{" "}
				<a href={registerHref} class="font-medium text-[#111827] underline underline-offset-2 transition-colors hover:text-[#111827]">Sign up</a>
			</p>
		</div>
		<div slot="c10" class="mx-auto flex h-full w-full max-w-[30rem] flex-col items-center justify-center gap-3">
			<form id="nz-login-form" data-auth-credentials-form class="flex w-full flex-col gap-2">
				<label class="flex flex-col gap-1 text-sm font-medium text-[#111827]">
					<span>Email</span>
					<input
						type="email"
						name="email"
						data-auth-email-input
						autocomplete="email"
						inputmode="email"
						spellcheck="false"
						required
						placeholder="me@company.com"
						value={initialEmail}
						class={authControlClass}
					/>
				</label>
				<label class="flex flex-col gap-1 text-sm font-medium text-[#111827]">
					<span>Password</span>
					<input
						type="password"
						name="password"
						data-auth-password-input
						autocomplete="current-password"
						required
						minlength="8"
						placeholder="Your password"
						class={authControlClass}
					/>
				</label>
			</form>
			<button
				type="submit"
				form="nz-login-form"
				data-auth-credentials-submit
				data-default-label="Sign in"
				class={`${authBtnClass} w-full`}
			>
				<AuthButtonSpinner />
				<span data-auth-btn-label>Sign in</span>
			</button>
		</div>
	</AuthGrid>
</div>

<script>
	import { bindAuthCredentialsFlow } from "@/scripts/auth-credentials-flow";

	function bindLogin() {
		const root = document.getElementById("nz-login-root");
		if (!root) return;
		const callbackUrl = root.dataset.callbackUrl || "/dashboard/agent";

		bindAuthCredentialsFlow({
			root,
			callbackUrl,
			intent: "login",
		});
	}

	bindLogin();
	document.addEventListener("astro:page-load", bindLogin);
</script>
