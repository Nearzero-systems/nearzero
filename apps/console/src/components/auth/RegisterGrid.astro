---
import AuthGrid from "./AuthGrid.astro";
import AuthButtonSpinner from "./AuthButtonSpinner.astro";
import {
	authBtnClass,
	authControlClass,
	authMutedText,
} from "@/lib/auth-form-classes";
import {
	HEARD_ABOUT_OPTIONS,
	MIGRATION_OPTIONS,
	MONTHLY_CALL_VOLUME_OPTIONS,
	ON_PREM_OPTIONS,
	ROLE_OPTIONS,
	isOnboardingRegisterStep,
	parseRegisterStep,
	stepSubtitle,
	stepTitle,
} from "@/lib/register-onboarding";

interface Props {
	loginHref?: string;
	invitationToken?: string;
	initialEmail?: string;
	lockEmail?: boolean;
	initialStep?: string;
	workspaceSetupMode?: boolean;
	inviteMemberSetupMode?: boolean;
}

const {
	loginHref = "/login",
	invitationToken = "",
	initialEmail = "",
	lockEmail = false,
	initialStep = "",
	workspaceSetupMode = false,
	inviteMemberSetupMode = false,
} = Astro.props;

const parsedStep = parseRegisterStep(initialStep);
const isOnboardingStep = isOnboardingRegisterStep(parsedStep);
const showSignupStage = !isOnboardingStep;
const initialTitle = workspaceSetupMode
	? "Create your workspace"
	: inviteMemberSetupMode
		? parsedStep === "profile"
			? "Welcome to the team"
			: stepTitle(parsedStep)
		: isOnboardingStep
			? stepTitle(parsedStep)
			: "Welcome to Nearzero";
const initialSubtitle = workspaceSetupMode
	? "Your invitation is no longer active. Enter your name and workspace name to continue."
	: inviteMemberSetupMode
		? parsedStep === "profile"
			? "Enter your name to finish joining the workspace."
			: stepSubtitle(parsedStep)
		: isOnboardingStep
			? stepSubtitle(parsedStep)
			: "";

const skipBtnClass =
	"inline-flex w-auto min-w-[9rem] items-center justify-center gap-2 self-center border-0 bg-transparent px-5 py-1.5 text-xs font-normal text-[#9ca3af] transition-colors duration-200 hover:bg-transparent hover:text-[#6b7280] disabled:cursor-not-allowed disabled:opacity-70";
const onboardingSelectClass =
	"w-full rounded-md border border-[#e5e7eb] bg-[#f7f7f8] px-2 py-1 text-sm text-[#111827] outline-none transition-colors focus:border-[#d1d5db]";
const onboardingBtnClass =
	"inline-flex w-auto min-w-[9rem] items-center justify-center gap-2 self-center rounded-md border border-[#e5e7eb] bg-[#f7f7f8] px-5 py-1.5 text-xs font-normal text-[#111827] transition-colors duration-200 hover:bg-white disabled:cursor-not-allowed disabled:opacity-70";
---

<div
	id="nz-register-root"
	class="contents"
	data-initial-email={initialEmail}
	data-invitation-token={invitationToken}
	data-login-href={loginHref}
	data-initial-step={initialStep}
	data-workspace-setup={workspaceSetupMode ? "1" : "0"}
	data-invite-member-setup={inviteMemberSetupMode ? "1" : "0"}
>
	<AuthGrid expandFormTile={showSignupStage}>
		<div slot="c4" class="mx-auto flex h-full w-full max-w-[30rem] flex-col items-center justify-end gap-1 pb-1 text-center">
			<p class={`hidden text-xs uppercase tracking-wide ${authMutedText}`} data-register-progress></p>
			<h1 class="font-display text-2xl font-semibold tracking-tight text-[#111827] sm:text-3xl" data-register-title>
				{initialTitle}
			</h1>
		</div>
		<div slot="c7" class="mx-auto flex h-full w-full max-w-[30rem] items-center justify-center px-3 text-center">
			<p class={`text-sm ${authMutedText} ${initialSubtitle ? "" : "hidden"}`} data-register-subtitle>
				{initialSubtitle}
			</p>
			<p class={`text-sm ${authMutedText} ${showSignupStage ? "" : "hidden"}`} data-register-login-link>
				Already have an account?{" "}
				<a href={loginHref} class="font-medium text-[#111827] underline underline-offset-2 transition-colors hover:text-[#111827]">Log in</a>
			</p>
		</div>
		<div slot="c10" class="mx-auto flex h-full min-h-0 w-full max-w-[30rem] flex-col items-center justify-center gap-3 overflow-visible px-1">
			<div data-register-stage="signup" class={showSignupStage ? "flex w-full flex-col items-center gap-3" : "hidden"}>
				<form id="nz-register-form" data-auth-credentials-form class="flex w-full flex-col gap-2">
					<label class="flex flex-col gap-1 text-sm font-medium text-[#111827]">
						<span>Email</span>
						<input
							type="email"
							name="email"
							data-auth-email-input
							autocomplete="email"
							inputmode="email"
							spellcheck="false"
							required
							placeholder="me@company.com"
							value={initialEmail}
							readonly={lockEmail}
							class={`${authControlClass}${lockEmail ? " cursor-not-allowed opacity-80" : ""}`}
						/>
					</label>
					<label class="flex flex-col gap-1 text-sm font-medium text-[#111827]">
						<span>Password</span>
						<input
							type="password"
							name="password"
							data-auth-password-input
							autocomplete="new-password"
							required
							minlength="8"
							placeholder="At least 8 characters"
							class={authControlClass}
						/>
					</label>
				</form>
				<button
					type="submit"
					form="nz-register-form"
					data-auth-credentials-submit
					data-default-label="Create an account"
					class={`${authBtnClass} w-full`}
				>
					<AuthButtonSpinner />
					<span data-auth-btn-label>Create an account</span>
				</button>
			</div>

			<div data-register-stage="profile" class={parsedStep === "profile" ? "min-h-0 w-full" : "hidden min-h-0 w-full"}>
				<form data-onboarding-profile-form class="flex flex-col gap-2.5">
					<label class="flex flex-col gap-1 text-sm font-medium text-[#111827]">
						<span>Your name</span>
						<input type="text" data-profile-name autocomplete="name" placeholder="Your name" class={authControlClass} />
					</label>
					<label class={`flex flex-col gap-1 text-sm font-medium text-[#111827] ${inviteMemberSetupMode ? "hidden" : ""}`}>
						<span>Organization name</span>
						<input type="text" data-profile-workspace autocomplete="organization" placeholder="Acme Inc." class={authControlClass} />
					</label>
				</form>
			</div>

			<div data-register-stage="role" class={parsedStep === "role" ? "min-h-0 w-full" : "hidden min-h-0 w-full"}>
				<form data-onboarding-role-form class="flex min-h-0 flex-col gap-2.5">
					<label class="flex flex-col gap-1 text-sm font-medium text-[#111827]">
						<span>What best describes you?</span>
						<select data-role-select class={onboardingSelectClass} required>
							<option value="">Select one</option>
							{ROLE_OPTIONS.map((option) => (
								<option value={option}>{option}</option>
							))}
						</select>
					</label>
					<label class="flex flex-col gap-1 text-sm font-medium text-[#111827]">
						<span>Do you need on-prem deployment for compliance or data residency?</span>
						<select data-onprem-select class={onboardingSelectClass} required>
							<option value="">Select one</option>
							{ON_PREM_OPTIONS.map((option) => (
								<option value={option}>{option}</option>
							))}
						</select>
					</label>
					<label class="flex flex-col gap-1 text-sm font-medium text-[#111827]">
						<span>Expected monthly deploy volume</span>
						<select data-call-volume-select class={onboardingSelectClass} required>
							<option value="">Select one</option>
							{MONTHLY_CALL_VOLUME_OPTIONS.map((option) => (
								<option value={option}>{option}</option>
							))}
						</select>
					</label>
					<label class="flex flex-col gap-1 text-sm font-medium text-[#111827]">
						<span>Are you migrating from another provider?</span>
						<select data-migration-select class={onboardingSelectClass} required>
							<option value="">Select one</option>
							{MIGRATION_OPTIONS.map((option) => (
								<option value={option}>{option}</option>
							))}
						</select>
					</label>
				</form>
			</div>

			<div data-register-stage="workspace" class={parsedStep === "workspace" ? "min-h-0 w-full" : "hidden min-h-0 w-full"}>
				<form data-onboarding-heard-form class="flex min-h-0 flex-col gap-2.5">
					<label class="flex flex-col gap-1 text-sm font-medium text-[#111827]">
						<span>How did you hear about us?</span>
						<select data-heard-about-select class={onboardingSelectClass} required>
							<option value="">Select an option</option>
							{HEARD_ABOUT_OPTIONS.map((option) => (
								<option value={option}>{option}</option>
							))}
						</select>
					</label>
				</form>
			</div>

			<div data-register-stage="invite" class={parsedStep === "invite" && !inviteMemberSetupMode ? "min-h-0 w-full" : "hidden min-h-0 w-full"}>
				<form id="nz-onboarding-invite-form" data-onboarding-invite-form class="flex min-h-0 flex-col">
					<label class="flex flex-col gap-1 text-sm font-medium text-[#111827]">
						<span>Teammate emails</span>
						<textarea
							data-invite-emails
							rows="2"
							placeholder="colleague@company.com, teammate@company.com"
							class={`${authControlClass} min-h-[3.25rem] resize-none py-2`}
						></textarea>
					</label>
				</form>
			</div>
		</div>
		<div slot="c13" class="mx-auto flex h-full w-full max-w-[36rem] flex-col justify-center gap-2">
			<div
				data-onboarding-actions
				class={
					isOnboardingStep && parsedStep !== "invite"
						? "flex w-full max-w-[30rem] flex-col items-center gap-2"
						: "hidden w-full max-w-[30rem] flex-col items-center gap-2"
				}
			>
				<button
					type="button"
					data-onboarding-continue
					data-default-label={
						workspaceSetupMode
							? "Create workspace"
							: inviteMemberSetupMode && parsedStep === "workspace"
								? "Finish"
								: "Continue"
					}
					class={onboardingBtnClass}
				>
					<AuthButtonSpinner />
					<span data-auth-btn-label>
						{workspaceSetupMode
							? "Create workspace"
							: inviteMemberSetupMode && parsedStep === "workspace"
								? "Finish"
								: "Continue"}
					</span>
				</button>
				<button
					type="button"
					data-onboarding-skip
					data-default-label="Skip"
					class={`${skipBtnClass} ${workspaceSetupMode || inviteMemberSetupMode ? "hidden" : "hidden"}`}
				>
					<AuthButtonSpinner />
					<span data-auth-btn-label>Skip</span>
				</button>
			</div>
			<div
				data-onboarding-invite-actions
				class={
					parsedStep === "invite"
						? "flex w-full max-w-[30rem] flex-col items-center gap-2"
						: "hidden w-full max-w-[30rem] flex-col items-center gap-2"
				}
			>
				<button
					type="submit"
					form="nz-onboarding-invite-form"
					data-invite-submit
					data-default-label="Send invites and finish"
					class={onboardingBtnClass}
				>
					<AuthButtonSpinner />
					<span data-auth-btn-label>Send invites and finish</span>
				</button>
				<button type="button" data-invite-skip data-default-label="Skip for now" class={skipBtnClass}>
					<AuthButtonSpinner />
					<span data-auth-btn-label>Skip for now</span>
				</button>
			</div>
		</div>
	</AuthGrid>
</div>

<script>
	import { invitationPath, resolveInvitationTokenFromPage } from "@/lib/invitation-routes";
	import { bindAuthCredentialsFlow } from "@/scripts/auth-credentials-flow";
	import { parseRegisterStep, registerStepPath, isOnboardingRegisterStep } from "@/lib/register-onboarding";
	import {
		bindRegisterOnboarding,
	} from "@/scripts/register-onboarding";

	function bindRegister() {
		const root = document.getElementById("nz-register-root");
		if (!root) return;

		const step = parseRegisterStep(
			root.dataset.initialStep ||
				new URL(window.location.href).searchParams.get("step"),
		);
		const inviteToken =
			root.dataset.invitationToken?.trim() ||
			resolveInvitationTokenFromPage() ||
			"";

		if (isOnboardingRegisterStep(step)) {
			if (
				inviteToken &&
				root.dataset.workspaceSetup !== "1" &&
				root.dataset.inviteMemberSetup !== "1"
			) {
				window.location.href = invitationPath(inviteToken);
				return;
			}
			void bindRegisterOnboarding(root);
			return;
		}

		if (root.dataset.registerBound !== "1") {
			root.dataset.registerBound = "1";
			const inviteEmail = root.dataset.initialEmail?.trim() || "";

			const afterSignupUrl = inviteToken
				? invitationPath(inviteToken, inviteEmail)
				: registerStepPath("profile", "/register", {
						token: inviteToken || undefined,
						email: inviteEmail || undefined,
					});

			bindAuthCredentialsFlow({
				root,
				callbackUrl: "/dashboard/agent",
				intent: "signup",
				invitationToken: inviteToken,
				afterSignupUrl,
			});
		}
	}

	bindRegister();
	document.addEventListener("astro:page-load", bindRegister);
</script>
