---
import AuthGrid from "./AuthGrid.astro";
import { authBtnClass, authControlClass, authMutedText } from "@/lib/auth-form-classes";

interface Props {
	loginHref?: string;
}

const { loginHref = "/login" } = Astro.props;
---

<div id="nz-send-reset-root">
	<AuthGrid>
		<div slot="c4" class="mx-auto flex h-full w-full max-w-[30rem] items-end justify-center pb-1 text-center">
			<h1 class="font-display text-2xl font-semibold tracking-tight text-[#111827] sm:text-3xl">Reset your password</h1>
		</div>
		<div slot="c7" class="mx-auto flex h-full w-full max-w-[30rem] items-center justify-center px-3 text-center">
			<p class={`text-sm ${authMutedText}`}>
				Enter your email and we'll send you a reset link.
			</p>
		</div>
		<div slot="c10" class="mx-auto flex h-full w-full max-w-[30rem] flex-col justify-center gap-1.5">
			<form id="nz-send-reset-form" class="flex flex-col gap-2">
				<label class="flex flex-col gap-1 text-sm font-medium text-[#111827]">
					<span>Email</span>
					<input type="email" name="email" autocomplete="email" required placeholder="me@company.com" class={authControlClass} />
				</label>
				<button type="submit" id="nz-send-reset-submit" class={authBtnClass}>
					<span id="nz-send-reset-submit-label">Send reset link</span>
				</button>
			</form>
			<p id="nz-send-reset-success" class="hidden text-center text-sm text-[#065f46]">
				If this email exists in our system, check your inbox for the reset link.
			</p>
		</div>
		<div slot="c16" class="mx-auto flex h-full w-full max-w-[36rem] flex-col items-center justify-center gap-3 text-center text-[11px] text-[#a3a3a3] sm:text-xs">
			<a href={loginHref} class="text-[#111827] underline underline-offset-2 transition-colors hover:text-[#111827]">Back to sign in</a>
		</div>
	</AuthGrid>
</div>

<script>
	import { authErrorMessage } from "@/lib/auth-form-classes";
	import { showToast } from "@/scripts/ui";

	function bindSendReset() {
		const root = document.getElementById("nz-send-reset-root");
		if (!root || root.dataset.bound === "1") return;
		root.dataset.bound = "1";

		const form = document.getElementById("nz-send-reset-form");
		const submit = document.getElementById("nz-send-reset-submit");
		const submitLabel = document.getElementById("nz-send-reset-submit-label");
		const success = document.getElementById("nz-send-reset-success");
		if (!(form instanceof HTMLFormElement) || !(submit instanceof HTMLButtonElement)) return;

		form.addEventListener("submit", async (e) => {
			e.preventDefault();
			const fd = new FormData(form);
			const email = String(fd.get("email") || "").trim();
			submit.disabled = true;
			if (submitLabel) submitLabel.textContent = "Sending...";
			try {
				const redirectTo = `${window.location.origin}/reset-password`;
				const res = await fetch("/api/auth/request-password-reset", {
					method: "POST",
					headers: { "content-type": "application/json" },
					credentials: "include",
					body: JSON.stringify({ email, redirectTo }),
				});
				const data = await res.json().catch(() => ({}));
				if (!res.ok) {
					showToast(authErrorMessage(data, "Could not send reset email"), "error");
					return;
				}
				form.classList.add("hidden");
				success?.classList.remove("hidden");
			} catch {
				showToast("Could not reach the auth server", "error");
			} finally {
				submit.disabled = false;
				if (submitLabel) submitLabel.textContent = "Send reset link";
			}
		});
	}

	bindSendReset();
	document.addEventListener("astro:page-load", bindSendReset);
</script>
