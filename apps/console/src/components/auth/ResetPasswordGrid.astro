---
import AuthGrid from "./AuthGrid.astro";
import { authBtnClass, authControlClass, authMutedText } from "@/lib/auth-form-classes";

interface Props {
	token: string;
	error: string;
	loginHref?: string;
}

const { token, error, loginHref = "/login" } = Astro.props;
const hasToken = token.length > 0;
const tokenError = error === "INVALID_TOKEN";
---

<div
	id="nz-reset-password-root"
	data-token={token}
	data-has-token={hasToken ? "1" : "0"}
	data-token-error={tokenError ? "1" : "0"}
>
	<AuthGrid>
		<div slot="c4" class="mx-auto flex h-full w-full max-w-[30rem] items-end justify-center pb-1 text-center">
			<h1 class="font-display text-2xl font-semibold tracking-tight text-[#111827] sm:text-3xl">Choose a new password</h1>
		</div>
		<div slot="c7" class="mx-auto flex h-full w-full max-w-[30rem] items-center justify-center px-3 text-center">
			{tokenError || !hasToken ? (
				<p class="text-sm text-[#991b1b]">
					{tokenError
						? "This reset link is invalid or has expired."
						: "Missing reset token. Request a new link from the sign-in page."}
				</p>
			) : (
				<p class={`text-sm ${authMutedText}`}>Enter your new password below.</p>
			)}
		</div>
		<div slot="c10" class="mx-auto flex h-full w-full max-w-[30rem] flex-col justify-center gap-1.5">
			{hasToken && !tokenError ? (
				<form id="nz-reset-password-form" class="flex flex-col gap-2">
					<label class="flex flex-col gap-1 text-sm font-medium text-[#111827]">
						<span>New password</span>
						<input type="password" name="password" autocomplete="new-password" required minlength="8" placeholder="••••••••" class={authControlClass} />
					</label>
					<label class="flex flex-col gap-1 text-sm font-medium text-[#111827]">
						<span>Confirm password</span>
						<input type="password" name="confirmPassword" autocomplete="new-password" required minlength="8" placeholder="••••••••" class={authControlClass} />
					</label>
					<button type="submit" id="nz-reset-password-submit" class={authBtnClass}>
						<span id="nz-reset-password-submit-label">Update password</span>
					</button>
				</form>
			) : (
				<a href="/send-reset-password" class={`${authBtnClass} text-center no-underline`}>Request a new reset link</a>
			)}
		</div>
		<div slot="c16" class="mx-auto flex h-full w-full max-w-[36rem] flex-col items-center justify-center gap-3 text-center text-[11px] text-[#a3a3a3] sm:text-xs">
			<a href={loginHref} class="text-[#111827] underline underline-offset-2 transition-colors hover:text-[#111827]">Back to sign in</a>
		</div>
	</AuthGrid>
</div>

<script>
	import { authErrorMessage } from "@/lib/auth-form-classes";
	import { showToast } from "@/scripts/ui";

	function bindResetPassword() {
		const root = document.getElementById("nz-reset-password-root");
		if (!root || root.dataset.bound === "1") return;
		if (root.dataset.hasToken !== "1" || root.dataset.tokenError === "1") return;
		root.dataset.bound = "1";

		const token = root.dataset.token || "";
		const form = document.getElementById("nz-reset-password-form");
		const submit = document.getElementById("nz-reset-password-submit");
		const submitLabel = document.getElementById("nz-reset-password-submit-label");
		if (!(form instanceof HTMLFormElement) || !(submit instanceof HTMLButtonElement)) return;

		form.addEventListener("submit", async (e) => {
			e.preventDefault();
			const fd = new FormData(form);
			const password = String(fd.get("password") || "");
			const confirmPassword = String(fd.get("confirmPassword") || "");
			if (password !== confirmPassword) {
				showToast("Passwords do not match", "error");
				return;
			}
			submit.disabled = true;
			if (submitLabel) submitLabel.textContent = "Updating...";
			try {
				const res = await fetch("/api/auth/reset-password", {
					method: "POST",
					headers: { "content-type": "application/json" },
					credentials: "include",
					body: JSON.stringify({ newPassword: password, token }),
				});
				const data = await res.json().catch(() => ({}));
				if (!res.ok) {
					showToast(authErrorMessage(data, "Could not reset password"), "error");
					return;
				}
				showToast("Password updated. Sign in with your new password.", "success");
				window.location.href = "/login";
			} catch {
				showToast("Could not reach the auth server", "error");
			} finally {
				submit.disabled = false;
				if (submitLabel) submitLabel.textContent = "Update password";
			}
		});
	}

	bindResetPassword();
	document.addEventListener("astro:page-load", bindResetPassword);
</script>
