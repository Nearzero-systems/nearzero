---
import "../styles/auth-grid.css";
import { AUTH_TILE_CLASS, AUTH_TILE_CONTENT_CLASS } from "@/lib/auth-grid-classes";

interface Props {
	variant?: "default" | "compact";
}

const { variant = "default" } = Astro.props;
const isCompact = variant === "compact";
const gridClass = isCompact ? "nz-auth-grid nz-auth-grid--compact" : "nz-auth-grid";

function tileClass(hasSlot: boolean) {
	return hasSlot ? AUTH_TILE_CONTENT_CLASS : AUTH_TILE_CLASS;
}
---

{isCompact ? (
	<div class={gridClass}>
		<div class={tileClass(false)}></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(true)}><slot name="c4" /></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(true)}><slot name="c7" /></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(true)}><slot name="c10" /></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(true)}><slot name="c16" /></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(false)}></div>
	</div>
) : (
	<div class={gridClass}>
		<div class={tileClass(false)}></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(true)}><slot name="c4" /></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(true)}><slot name="c7" /></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(true)}><slot name="c10" /></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(true)}><slot name="c13" /></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(true)}><slot name="c16" /></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(false)}></div>
		<div class={tileClass(false)}></div>
	</div>
)}
