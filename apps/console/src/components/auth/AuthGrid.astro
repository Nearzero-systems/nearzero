---
import {
	AUTH_GRID_CLASS_NAME,
	AUTH_TILE_BASE_CLASS,
	loginTileClassName,
} from "@/lib/auth-grid-classes";

function tile(index: number, hasSlot: boolean) {
	return `${AUTH_TILE_BASE_CLASS} ${loginTileClassName(index, hasSlot)}`.trim();
}
---

<div class={AUTH_GRID_CLASS_NAME}>
	<div class={tile(0, false)}></div>
	<div class={tile(1, false)}></div>
	<div class={tile(2, false)}></div>
	<div class={tile(3, false)}></div>
	<div class={tile(4, true)}><slot name="c4" /></div>
	<div class={tile(5, false)}></div>
	<div class={tile(6, false)}></div>
	<div class={tile(7, true)}><slot name="c7" /></div>
	<div class={tile(8, false)}></div>
	<div class={tile(9, false)}></div>
	<div class={tile(10, true)}><slot name="c10" /></div>
	<div class={tile(11, false)}></div>
	<div class={tile(12, false)}></div>
	<div class={tile(13, true)}><slot name="c13" /></div>
	<div class={tile(14, false)}></div>
	<div class={tile(15, false)}></div>
	<div class={tile(16, true)}><slot name="c16" /></div>
	<div class={tile(17, false)}></div>
	<div class={tile(18, false)}></div>
	<div class={tile(19, false)}></div>
	<div class={tile(20, false)}></div>
</div>
