---
import SettingsToneBadge from "./SettingsToneBadge.astro";
import { buttonClass } from "../dashboard/demoShared";

interface SettingRow {
  label: string;
  value: string;
  detail: string;
  action: string;
  tone?: "default" | "success" | "warn" | "accent";
}

interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  rows: SettingRow[];
  ctaLabel?: string;
  ctaHref?: string;
}

const { eyebrow, title, description = "", rows, ctaLabel, ctaHref } = Astro.props;
const sectionCardClass = "rounded-md border border-[#eceef3] bg-white px-4 py-5 sm:px-6 sm:py-6";
const sectionRowClass =
  "grid gap-3 border-t border-[#eceef3] py-4 first:border-t-0 first:pt-0 last:pb-0 md:grid-cols-[160px_minmax(0,1fr)_140px_auto] md:items-start";
---

<section class={sectionCardClass}>
  <div class="flex flex-wrap items-center justify-between gap-3 border-b border-[#eceef3] pb-4">
    <div class="max-w-3xl">
      <p class="text-xs text-[#6b7280]">{eyebrow}</p>
      <h2 class="mt-2 text-lg font-semibold text-[#111827]">{title}</h2>
      {description ? <p class="mt-1 text-sm text-[#6b7280]">{description}</p> : null}
    </div>

    {ctaLabel ? (
      ctaHref ? (
        <a href={ctaHref} class={buttonClass}>{ctaLabel}</a>
      ) : (
        <button type="button" class={buttonClass}>{ctaLabel}</button>
      )
    ) : null}
  </div>

  <div class="pt-4">
    {rows.map((row) => (
      <div class={sectionRowClass}>
        <div>
          <p class="text-sm font-medium text-[#111827]">{row.label}</p>
        </div>
        <p class="text-sm leading-7 text-[#6b7280]">{row.detail}</p>
        <SettingsToneBadge tone={row.tone}>{row.value}</SettingsToneBadge>
        <div class="md:justify-self-end">
          <button type="button" class={buttonClass}>{row.action}</button>
        </div>
      </div>
    ))}
  </div>
</section>
