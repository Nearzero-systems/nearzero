---
import { badgeClass, buttonClass, cardClass } from "./demoShared";

interface Props {
  meta: {
    eyebrow: string;
    title: string;
    description: string;
    ctaLabel?: string;
    ctaHref?: string;
  };
  projectsCount: number;
  deploymentsCount: number;
  domainsCount: number;
  objectsCount: number;
  latestDeployName: string;
  glacierTotalSizeLabel: string;
  currentPlanLabel: string;
}

const {
  meta,
  projectsCount,
  deploymentsCount,
  domainsCount,
  objectsCount,
  latestDeployName,
  glacierTotalSizeLabel,
  currentPlanLabel,
} = Astro.props;
---

<div class="grid gap-px xl:grid-cols-[minmax(0,1.35fr)_minmax(320px,0.9fr)]">
  <div class={`${cardClass} min-h-[190px]`}>
    <p class="text-xs text-[#6b7280]">
      {meta.eyebrow}
    </p>
    <h1 class="font-display mt-3 max-w-3xl text-[24px] font-semibold tracking-tight text-[#111827] md:text-[32px]">
      {meta.title}
    </h1>
    <p class="mt-3 max-w-3xl text-xs leading-6 text-[#6b7280]">
      {meta.description}
    </p>
    <div class="mt-4 flex flex-wrap gap-2">
      <span class={badgeClass}>{projectsCount} projects</span>
      <span class={badgeClass}>{deploymentsCount} deployments</span>
      <span class={badgeClass}>{domainsCount} domains</span>
      <span class={badgeClass}>{objectsCount} objects</span>
    </div>
    {meta.ctaLabel && meta.ctaHref ? (
      <a class={`${buttonClass} mt-4`} href={meta.ctaHref}>
        {meta.ctaLabel}
      </a>
    ) : null}
  </div>

  <div class={`${cardClass} grid content-start gap-px sm:grid-cols-2`}>
    <div class="rounded-md bg-[#f7f7f8] px-3 py-3">
      <p class="text-xs text-[#6b7280]">
        Environment
      </p>
      <p class="mt-2 text-sm font-medium text-[#111827]">production</p>
    </div>
    <div class="rounded-md bg-[#f7f7f8] px-3 py-3">
      <p class="text-xs text-[#6b7280]">
        Plan
      </p>
      <p class="mt-2 text-sm font-medium text-[#111827]">{currentPlanLabel}</p>
    </div>
    <div class="rounded-md bg-[#f7f7f8] px-3 py-3">
      <p class="text-xs text-[#6b7280]">
        Latest deploy
      </p>
      <p class="mt-2 text-sm font-medium text-[#111827]">{latestDeployName}</p>
    </div>
    <div class="rounded-md bg-[#f7f7f8] px-3 py-3">
      <p class="text-xs text-[#6b7280]">
        Storage footprint
      </p>
      <p class="mt-2 text-sm font-medium text-[#111827]">
        {glacierTotalSizeLabel}
      </p>
    </div>
  </div>
</div>
