---
import { buttonClass } from "../demoShared";
import ProjectCardActions from "./ProjectCardActions.astro";

interface Props {
  projectRows: any[];
  visible?: boolean;
}

const { projectRows, visible = false } = Astro.props;
---

<div
  class:list={[
    "project-view min-h-[calc(100dvh-77px)] px-4 py-4 sm:px-6",
    { hidden: !visible },
  ]}
  data-project-view="inventory"
>
  <div class="mx-auto flex h-full w-full max-w-[1100px] flex-col">
    <div class="flex flex-col gap-3 border-b border-[#eceef3] pb-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-xs text-[#6b7280]">
          Projects
        </p>
        <h2 class="font-display mt-2 text-[22px] font-semibold tracking-tight text-[#111827] sm:text-[28px]">
          Workspace projects
        </h2>
      </div>

      <button
        type="button"
        class={buttonClass}
        data-project-open-import
      >
        Add Project
      </button>
    </div>

    <div class="grid gap-2 pt-4 md:grid-cols-2 xl:grid-cols-3">
      {projectRows.map((project) => (
        <article
          class:list={[
            "group relative rounded-md border border-[#eceef3] bg-white px-4 py-4 transition-colors hover:border-[#d9dbe3]",
            project.cardHref ? "cursor-pointer" : "",
          ]}
          data-project-card-href={project.cardHref || undefined}
          tabindex={project.cardHref ? "0" : undefined}
          role={project.cardHref ? "link" : undefined}
        >
          <div>
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="truncate text-sm font-medium text-[#111827]">
                  {project.name}
                </p>
              </div>

              <div class="flex items-center gap-2">
                {project.visitHref ? (
                  <a
                    class="inline-flex items-center justify-center rounded-md border border-[#d9dbe3] bg-[#f7f7f8] px-2 py-1 text-xs text-[#111827] transition-colors hover:bg-white"
                    href={project.visitHref}
                    target="_blank"
                    rel="noopener noreferrer"
                    data-project-card-ignore
                  >
                    Visit
                  </a>
                ) : null}
                <ProjectCardActions
                  projectId={project.id}
                  projectName={project.name}
                  settingsHref={project.settingsHref}
                />
              </div>
            </div>

            <div class="mt-3 flex flex-wrap items-center gap-2">
              <span class="inline-flex max-w-full items-center rounded-full bg-[#f3f4f6] px-3 py-1 text-xs text-[#4b5563]">
                <span class="truncate">{project.repoLabel}</span>
              </span>
            </div>

            <div class="mt-3 flex flex-wrap items-center gap-2 text-xs text-[#6b7280]">
              <a
                class="font-mono text-[11px] text-[#4b5563] underline decoration-[#c7cfdb] underline-offset-4 transition-colors hover:text-[#111827]"
                href={project.detailsHref}
              >
                {project.deploymentIdLabel}
              </a>
            </div>

            <p class="mt-4 text-xs leading-6 text-[#6b7280]">
              {project.activityLabel}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const script = document.currentScript;
    const root = script?.previousElementSibling;
    if (!(root instanceof HTMLElement) || root.dataset.cardBound === "true") {
      return;
    }
    root.dataset.cardBound = "true";

    root.querySelectorAll("[data-project-card-href]").forEach((node) => {
      if (!(node instanceof HTMLElement)) return;
      node.addEventListener("click", (event) => {
        const href = String(node.dataset.projectCardHref || "").trim();
        if (!href) return;
        const target = event.target;
        if (!(target instanceof Element)) return;
        if (target.closest("a, button, input, textarea, select, label, [role='button'], [data-project-card-ignore]")) {
          return;
        }
        window.location.assign(href);
      });
      node.addEventListener("keydown", (event) => {
        const href = String(node.dataset.projectCardHref || "").trim();
        if (!href) return;
        const target = event.target;
        if (!(target instanceof Element)) return;
        if (target.closest("a, button, input, textarea, select, label, [role='button'], [data-project-card-ignore]")) {
          return;
        }
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          window.location.assign(href);
        }
      });
    });
  })();
</script>
