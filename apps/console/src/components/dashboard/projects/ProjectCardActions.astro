---
interface Props {
  projectId: string;
  projectName: string;
  settingsHref: string;
}

const { projectId, projectName, settingsHref } = Astro.props;

const iconButtonClassName =
  "inline-flex items-center justify-center rounded-md border-0 bg-transparent px-2 py-1 font-sans text-xs text-[#111827] transition-colors hover:bg-[#f7f7f8]";
const menuButtonClassName =
  "flex w-full items-center rounded-md bg-white px-2 py-1.5 font-sans text-xs text-[#111827] transition-colors hover:bg-[#f7f7f8]";
const destructiveButtonClassName =
  "flex w-full items-center rounded-md bg-white px-2 py-1.5 font-sans text-xs text-[#b42318] transition-colors hover:bg-[#fff5f4]";
const actionButtonClassName =
  "inline-flex items-center justify-center rounded-md border border-[#d9dbe3] bg-white px-2 py-1 font-sans text-xs text-[#111827] transition-colors hover:bg-[#f7f7f8] disabled:cursor-not-allowed disabled:opacity-60";
const destructiveActionButtonClassName =
  "inline-flex items-center justify-center rounded-md border border-[#f1c2bd] bg-white px-2 py-1 font-sans text-xs text-[#b42318] transition-colors hover:bg-[#fff5f4] disabled:cursor-not-allowed disabled:opacity-60";
const inputClassName =
  "w-full rounded-md border border-[#d9dbe3] bg-white px-2 py-1 font-sans text-xs text-[#111827] outline-none transition-colors focus:border-[#c7cfdb]";
const panelClassName =
  "pointer-events-none absolute right-0 top-[calc(100%+0.45rem)] z-[500] w-[min(16.5rem,calc(100vw-2rem))] max-w-[calc(100vw-2rem)] translate-y-1 rounded-xl border border-[#e5e7eb] bg-white p-3.5 font-sans opacity-0 transition-all duration-200 ease-out sm:right-[-8rem] sm:w-[17.75rem] sm:max-w-none";
---

<div
  class="relative z-20"
  data-project-actions-root
  data-project-id={projectId}
  data-project-name={projectName}
  data-settings-href={settingsHref}
  data-project-card-ignore
>
  <button
    type="button"
    aria-label="Project actions"
    aria-expanded="false"
    class={iconButtonClassName}
    data-project-actions-trigger
    data-project-card-ignore
  >
    <svg viewBox="0 0 24 24" class="h-4 w-4" aria-hidden="true">
      <circle cx="5" cy="12" r="1.6" fill="currentColor"></circle>
      <circle cx="12" cy="12" r="1.6" fill="currentColor"></circle>
      <circle cx="19" cy="12" r="1.6" fill="currentColor"></circle>
    </svg>
  </button>

  <div class={panelClassName} data-project-actions-panel data-view="menu">
    <div data-project-actions-view="menu">
      <p class="font-sans text-xs font-medium text-[#111827]">Project actions</p>
      <p class="mt-1 font-sans text-xs text-[#6b7280]">
        Choose what you want to do with this project.
      </p>
      <div class="mt-3 flex flex-col gap-1.5">
        <button type="button" class={menuButtonClassName} data-project-open-settings>Project settings</button>
        <button type="button" class={menuButtonClassName} data-project-open-rename>Rename project</button>
        <button type="button" class={destructiveButtonClassName} data-project-open-delete>Delete project</button>
      </div>
    </div>

    <div class="hidden" data-project-actions-view="rename">
      <p class="font-sans text-xs font-medium text-[#111827]">Rename project</p>
      <p class="mt-1 font-sans text-xs text-[#6b7280]">Choose a new project name.</p>
      <div class="mt-3">
        <input
          type="text"
          value={projectName}
          class={inputClassName}
          data-project-rename-input
        />
      </div>
      <div class="mt-3 flex items-center justify-end gap-2">
        <button type="button" class={actionButtonClassName} data-project-back>Back</button>
        <button type="button" class={actionButtonClassName} data-project-save-rename>Save</button>
      </div>
    </div>

    <div class="hidden" data-project-actions-view="delete">
      <p class="font-sans text-xs font-medium text-[#111827]">Delete project</p>
      <p class="mt-1 font-sans text-xs text-[#6b7280]">
        This will remove {projectName} and its related records.
      </p>
      <div class="mt-3 rounded-md bg-white px-2 py-1.5 font-sans text-xs text-[#6b7280]">
        Delete project
      </div>
      <div class="mt-3 flex items-center justify-end gap-2">
        <button type="button" class={actionButtonClassName} data-project-back>Back</button>
        <button type="button" class={destructiveActionButtonClassName} data-project-confirm-delete>
          Delete project
        </button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const script = document.currentScript;
    const root = script?.previousElementSibling;
    if (!(root instanceof HTMLElement) || root.dataset.bound === "true") return;
    root.dataset.bound = "true";

    const trigger = root.querySelector("[data-project-actions-trigger]");
    const panel = root.querySelector("[data-project-actions-panel]");
    const renameInput = root.querySelector("[data-project-rename-input]");
    const viewNodes = Array.from(root.querySelectorAll("[data-project-actions-view]"));
    const backButtons = Array.from(root.querySelectorAll("[data-project-back]"));
    const openRenameButton = root.querySelector("[data-project-open-rename]");
    const openDeleteButton = root.querySelector("[data-project-open-delete]");
    const openSettingsButton = root.querySelector("[data-project-open-settings]");
    const saveRenameButton = root.querySelector("[data-project-save-rename]");
    const confirmDeleteButton = root.querySelector("[data-project-confirm-delete]");

    if (!(trigger instanceof HTMLButtonElement) || !(panel instanceof HTMLElement)) return;

    const projectId = String(root.dataset.projectId || "").trim();
    const projectName = String(root.dataset.projectName || "").trim();
    const settingsHref = String(root.dataset.settingsHref || "").trim();

    const openClasses = ["pointer-events-auto", "translate-y-0", "opacity-100"];
    const closedClasses = ["pointer-events-none", "translate-y-1", "opacity-0"];

    const showToast = (message) => {
      if (typeof window.nzShowToast === "function") {
        window.nzShowToast(message);
      }
    };

    const navigateTop = (href) => {
      const nextHref = String(href || "").trim();
      if (!nextHref) return;
      const anchor = document.createElement("a");
      anchor.href = nextHref;
      anchor.target = "_top";
      anchor.rel = "noopener noreferrer";
      anchor.style.display = "none";
      document.body.appendChild(anchor);
      anchor.click();
      anchor.remove();
    };

    const setView = (nextView) => {
      viewNodes.forEach((node) => {
        if (!(node instanceof HTMLElement)) return;
        node.classList.toggle("hidden", node.dataset.projectActionsView !== nextView);
      });
      panel.dataset.view = nextView;
      if (nextView === "rename" && renameInput instanceof HTMLInputElement) {
        window.setTimeout(() => renameInput.focus(), 30);
      }
    };

    const setOpen = (nextOpen) => {
      trigger.setAttribute("aria-expanded", nextOpen ? "true" : "false");
      panel.classList.remove(...(nextOpen ? closedClasses : openClasses));
      panel.classList.add(...(nextOpen ? openClasses : closedClasses));
      root.dataset.open = nextOpen ? "true" : "false";
      if (!nextOpen) setView("menu");
    };

    const setSubmitting = (submitting) => {
      root.dataset.submitting = submitting ? "true" : "false";
      root
        .querySelectorAll("button, input")
        .forEach((node) => {
          if (node instanceof HTMLButtonElement || node instanceof HTMLInputElement) {
            node.disabled = submitting;
          }
        });
    };

    setOpen(false);

    trigger.addEventListener("click", (event) => {
      event.preventDefault();
      event.stopPropagation();
      setOpen(root.dataset.open !== "true");
    });

    root.addEventListener("click", (event) => {
      event.stopPropagation();
    });

    document.addEventListener("click", (event) => {
      if (!(event.target instanceof Node)) return;
      if (!root.contains(event.target) && root.dataset.submitting !== "true") {
        setOpen(false);
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && root.dataset.submitting !== "true") {
        setOpen(false);
      }
    });

    if (openSettingsButton instanceof HTMLButtonElement) {
      openSettingsButton.addEventListener("click", () => navigateTop(settingsHref));
    }

    if (openRenameButton instanceof HTMLButtonElement) {
      openRenameButton.addEventListener("click", () => {
        if (renameInput instanceof HTMLInputElement) {
          renameInput.value = projectName;
        }
        setView("rename");
      });
    }

    if (openDeleteButton instanceof HTMLButtonElement) {
      openDeleteButton.addEventListener("click", () => setView("delete"));
    }

    backButtons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;
      button.addEventListener("click", () => setView("menu"));
    });

    if (saveRenameButton instanceof HTMLButtonElement) {
      saveRenameButton.addEventListener("click", async () => {
        const name = renameInput instanceof HTMLInputElement ? String(renameInput.value || "").trim() : "";
        if (!name) {
          showToast("Project name is required.");
          return;
        }
        setSubmitting(true);
        try {
          const res = await fetch(`/api/console-project?id=${encodeURIComponent(projectId)}`, {
            method: "PATCH",
            credentials: "include",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({ name }),
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok) {
            showToast(String(data?.error || "Failed to rename project."));
            return;
          }
          showToast("Project renamed.");
          window.location.reload();
        } catch {
          showToast("Could not rename the project right now.");
        } finally {
          setSubmitting(false);
        }
      });
    }

    if (confirmDeleteButton instanceof HTMLButtonElement) {
      confirmDeleteButton.addEventListener("click", async () => {
        setSubmitting(true);
        try {
          const res = await fetch(`/api/console-project?id=${encodeURIComponent(projectId)}`, {
            method: "DELETE",
            credentials: "include",
          });
          if (!res.ok && res.status !== 204) {
            const data = await res.json().catch(() => ({}));
            showToast(String(data?.error || "Failed to delete project."));
            return;
          }
          showToast("Project deleted.");
          navigateTop("/app?section=projects");
        } catch {
          showToast("Could not delete the project right now.");
        } finally {
          setSubmitting(false);
        }
      });
    }
  })();
</script>
