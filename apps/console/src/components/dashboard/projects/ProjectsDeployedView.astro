---
import { buttonClass } from "../demoShared";
---

<div
  class="project-view hidden min-h-[calc(100dvh-77px)] px-4 py-4 sm:px-6"
  data-project-view="deployed"
>
  <div class="mx-auto flex w-full max-w-[980px] flex-col gap-2">
    <div class="rounded-md border border-[#eceef3] bg-white px-4 py-5 sm:px-6 sm:py-6">
      <div class="flex flex-col gap-3 border-b border-[#eceef3] pb-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-xs text-[#6b7280]">
            Deployed
          </p>
          <h2 class="font-display mt-2 text-[22px] font-semibold tracking-tight text-[#111827] sm:text-[28px]">
            <span data-deployed-project-name>—</span> is live
          </h2>
        </div>

        <span class="inline-flex items-center rounded-md border border-[#d7ead8] bg-[#f3faf3] px-2 py-1 text-xs text-[#325c35]">
          Deployment successful
        </span>
      </div>

      <div class="mt-4 grid gap-2 md:grid-cols-3">
        <div class="rounded-md border border-[#eceef3] bg-[#fafafa] px-4 py-4">
          <p class="text-xs text-[#6b7280]">
            Provider
          </p>
          <p class="mt-3 text-sm font-medium text-[#111827]" data-deployed-provider-label>
            GitHub
          </p>
        </div>

        <div class="rounded-md border border-[#eceef3] bg-[#fafafa] px-4 py-4">
          <p class="text-xs text-[#6b7280]">
            Repo
          </p>
          <p class="mt-3 truncate text-sm font-medium text-[#111827]" data-deployed-repo-full>
            —
          </p>
        </div>

        <div class="rounded-md border border-[#eceef3] bg-[#fafafa] px-4 py-4">
          <p class="text-xs text-[#6b7280]">
            URL
          </p>
          <p class="mt-3 truncate text-sm font-medium text-[#111827]" data-deployed-url>
            —
          </p>
        </div>
      </div>

      <p class="mt-4 hidden text-xs text-[#6b7280]" data-deployed-deployment-id></p>
      <p class="mt-2 hidden text-xs" data-deployed-logs-wrap>
        <a
          class="font-sans text-[#3f2a6d] underline decoration-[#3f2a6d]/40 underline-offset-2 hover:decoration-[#3f2a6d]"
          data-deployed-logs-link
          href="#"
          >Open live build logs</a
        >
      </p>
    </div>

    <div class="rounded-md border border-[#eceef3] bg-white px-4 py-5 sm:px-6">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h3 class="text-sm font-medium text-[#111827]">
            Your default Nearzero domain is ready.
          </h3>
          <p class="mt-2 text-xs leading-6 text-[#6b7280]">
            Add a custom production domain now, or keep using the default Nearzero URL and come back later.
          </p>
        </div>

        <div class="flex flex-col gap-2 sm:flex-row">
          <a class={buttonClass} href="/app?section=domains">
            Add custom domain
          </a>
          <button
            type="button"
            class={buttonClass}
            data-project-finish
          >
            Back to projects
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
