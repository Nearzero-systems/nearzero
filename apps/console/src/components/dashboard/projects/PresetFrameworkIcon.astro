---
import { listFrameworkPresetOptions } from "@nearzero/spec";

const applicationPresets = listFrameworkPresetOptions();

const BRAND_COLOR: Record<string, string | undefined> = {
  astro: "#FF5D01",
  nextjs: "#000000",
  nuxt: "#00DC82",
  remix: "#121212",
  sveltekit: "#FF3E00",
  gatsby: "#663399",
  docusaurus: "#2E8555",
  vite: "#646CFF",
  react: "#61DAFB",
  vue: "#42B883",
  angular: "#DD0031",
  solidstart: "#2C4F7C",
  nodejs: "#539E43",
  nestjs: "#E0234E",
  express: "#111827",
  fastify: "#111827",
  hono: "#F97316",
  docker: "#2496ED",
  worker: "#F38020",
  python: "#3776AB",
  django: "#0C4B33",
  fastapi: "#009688",
  flask: "#111827",
  go: "#00ADD8",
  rust: "#000000",
  php: "#777BB4",
  laravel: "#FF2D20",
  other: undefined,
};

function presetAbbrev(id: string, label: string) {
  if (id === "other") return "··";
  return label.slice(0, 2);
}
---

<span
  class="inline-flex h-5 w-5 shrink-0 items-center justify-center"
  data-preset-framework-icon-root
  aria-hidden="true"
>
  {
    applicationPresets.map(({ id, label }) => {
      const color = BRAND_COLOR[id];
      return (
        <span
          class:list={[
            "inline-flex h-5 w-5 shrink-0 items-center justify-center rounded text-[9px] font-bold uppercase tracking-tight",
            id !== "other" && "hidden",
          ]}
          data-preset-framework-icon={id}
          style={
            color
              ? { color, backgroundColor: `${color}22` }
              : { color: "#9ca3af" }
          }
        >
          {presetAbbrev(id, label)}
        </span>
      );
    })
  }
  <span
    class="inline-flex h-5 w-5 shrink-0 items-center justify-center rounded text-[9px] font-bold text-[#9ca3af] hidden"
    data-preset-framework-icon="other"
  >
    ··
  </span>
</span>

<script is:inline>
  (() => {
    const script = document.currentScript;
    const root = script?.previousElementSibling;
    if (!(root instanceof HTMLElement) || root.dataset.bound === "true") {
      return;
    }
    root.dataset.bound = "true";

    const flow = document.querySelector("[data-project-flow-root]");
    const select = document.querySelector("[data-config-preset-select]");

    const applyPreset = (preset) => {
      const value = String(preset || "other").trim().toLowerCase() || "other";
      const icons = Array.from(root.querySelectorAll("[data-preset-framework-icon]"));
      let matched = false;
      icons.forEach((node) => {
        if (!(node instanceof HTMLElement)) return;
        const isMatch = node.dataset.presetFrameworkIcon === value;
        node.classList.toggle("hidden", !isMatch);
        if (isMatch) matched = true;
      });
      if (!matched) {
        const fallback = root.querySelector('[data-preset-framework-icon="other"]');
        if (fallback instanceof HTMLElement) {
          fallback.classList.remove("hidden");
        }
      }
    };

    const applyFromSelect = () => {
      if (select instanceof HTMLSelectElement) {
        applyPreset(select.value);
      }
    };

    const onDisplay = (event) => {
      const detail = event instanceof CustomEvent ? event.detail : undefined;
      applyPreset(detail?.preset);
    };

    flow?.addEventListener("nz-preset-display", onDisplay);
    select?.addEventListener("change", applyFromSelect);
    applyFromSelect();
  })();
</script>
