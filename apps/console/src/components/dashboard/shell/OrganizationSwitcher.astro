---
type OrgRow = {
	id: string;
	name?: string | null;
	slug?: string | null;
	logo?: string | null;
	ownerId?: string | null;
	members?: { isDefault?: boolean | null }[] | null;
};

interface Props {
	brandLabel?: string;
	organizations: OrgRow[];
	activeOrganization: OrgRow | null | undefined;
	dashboardRole?: string | null;
}

const {
	brandLabel = "Nearzero",
	organizations,
	activeOrganization,
} = Astro.props;

const canFooterAddOrg = true;

const isPlaceholderOrg = (org: OrgRow) =>
	(org.name?.trim() || "") === "My Organization";
const realOrganizations = organizations.filter((org) => !isPlaceholderOrg(org));
const visibleOrganizations =
	realOrganizations.length > 0 ? realOrganizations : organizations;
const displayActiveOrganization =
	visibleOrganizations.find((org) => org.id === activeOrganization?.id) ??
	visibleOrganizations[0] ??
	activeOrganization;
const activeName = displayActiveOrganization?.name?.trim() || "Organization";
---

<div class="flex min-w-0 max-w-[min(100%,28rem)] items-center gap-2 text-xs">
  <span class="shrink-0 font-display text-sm font-semibold tracking-tight text-[var(--nz-text)]">{brandLabel}</span>
  <span class="shrink-0 font-medium text-[color-mix(in_srgb,var(--nz-text-muted)_72%,var(--nz-text))]">/</span>
  <details class="relative min-w-0 nz-org-shell">
    <summary
      class="flex min-w-0 cursor-pointer list-none items-center gap-1 rounded-md px-1 py-1 transition-colors hover:bg-[var(--nz-bg-hover)] [&::-webkit-details-marker]:hidden"
    >
      <span class="min-w-0 truncate font-medium text-[var(--nz-text)]">{activeName}</span>
      <svg
        class="size-3.5 shrink-0 text-[var(--nz-text-subtle)]"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="m7 15 5 5 5-5"></path>
      <path d="m7 9 5-5 5 5"></path>
    </svg>
  </summary>
  <div
    class="absolute left-0 top-[calc(100%+0.375rem)] z-50 w-[12rem] max-w-[12rem] rounded-md border border-[var(--nz-border)] bg-[var(--nz-bg-elevated)] p-1 shadow-lg"
  >
    <div
      class="px-2 py-1 text-[10px] font-medium uppercase tracking-[0.14em] text-[var(--nz-text-subtle)]"
    >
      Organizations
    </div>
    <div class="max-h-[min(70vh,28rem)] overflow-y-auto">
      {
        visibleOrganizations.map((org) => {
          const isActive = displayActiveOrganization?.id === org.id;
          const orgName = org.name?.trim() || "Organization";

          return (
            <button
              type="button"
              class="nz-org-set-active flex w-full min-w-0 items-center gap-2 rounded-md px-2 py-1.5 text-left text-xs text-[var(--nz-text)] transition-colors hover:bg-[var(--nz-bg-hover)]"
              data-organization-id={org.id}
              data-organization-slug={org.slug ?? ""}
              aria-current={isActive ? "true" : undefined}
            >
              <span class="min-w-0 flex-1 truncate">{orgName}</span>
              {
                isActive ? (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="size-3.5 shrink-0 text-[var(--nz-text)]"
                    aria-hidden="true"
                  >
                    <path d="M20 6 9 17l-5-5" />
                  </svg>
                ) : null
              }
            </button>
          );
        })
      }
    </div>

    {
      canFooterAddOrg ? (
        <>
          <div class="-mx-1 my-1 h-px bg-[var(--nz-border)]" />
          <button
            type="button"
            class="nz-org-open-create flex w-full cursor-pointer items-center gap-2 rounded-md px-2 py-1.5 text-left text-xs text-[var(--nz-text-muted)] transition-colors hover:bg-[var(--nz-bg-hover)] hover:text-[var(--nz-text)]"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="size-3.5"
              aria-hidden="true"
            >
              <path d="M12 5v14" />
              <path d="M5 12h14" />
            </svg>
            Add organization
          </button>
        </>
      ) : null
    }
  </div>
  </details>
</div>
