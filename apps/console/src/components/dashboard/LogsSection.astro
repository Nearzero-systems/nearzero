---
import { cardClass } from "./demoShared";

interface Props {
  rows: Array<{ time: string; level: string; title: string; detail: string }>;
}

const { rows } = Astro.props;
---

<div class={cardClass}>
  <p class="text-xs text-[#6b7280]">
    Activity stream
  </p>
  <div class="mt-4 space-y-3">
    {rows.map((row) => (
      <div class="flex flex-col gap-3 rounded-md bg-[#f7f7f8] px-3 py-3 md:flex-row md:items-start md:justify-between">
        <div class="min-w-0">
          <div class="flex flex-wrap items-center gap-2">
            <span
              class={`rounded-md border px-2 py-1 text-xs ${
                row.level === "warn"
                  ? "border-[#f3dfb0] bg-[#fff8ea] text-[#925f00]"
                  : "border-[#d9dbe3] bg-white text-[#6b7280]"
              }`}
            >
              {row.level}
            </span>
            <p class="text-sm font-medium text-[#111827]">{row.title}</p>
          </div>
          <p class="mt-2 text-xs leading-6 text-[#6b7280]">{row.detail}</p>
        </div>
        <span class="text-xs text-[#9aa3b2]">{row.time}</span>
      </div>
    ))}
  </div>
</div>
