---
import DesktopSidebar from "./shell/DesktopSidebar.astro";
import type { NavContext } from "@/components/dashboard/navMenu";

interface Props {
	activeSection: string;
	dashboardAuth: {
		user?: {
			firstName?: string | null;
			lastName?: string | null;
			email?: string | null;
			image?: string | null;
		};
		role?: string | null;
	} | null;
	permissions: NavContext["permissions"] | null;
	orgSlug?: string | null;
	whitelabeling: NavContext["whitelabeling"] | null;
}

const {
	activeSection,
	dashboardAuth,
	permissions,
	orgSlug = null,
	whitelabeling,
} = Astro.props;
---

<div
  id="mobile-nav-root"
  aria-hidden="true"
  class="pointer-events-none fixed inset-0 z-[250] hidden lg:hidden"
>
  <button
    id="mobile-nav-overlay"
    type="button"
    aria-label="Close navigation"
    class="absolute inset-0 opacity-0 backdrop-blur-[0px] bg-[#111827]/8 transition-all duration-200 ease-in-out"
  ></button>
  <aside
    id="mobile-nav-sheet"
    class="absolute inset-y-0 left-0 flex h-screen w-[14.5rem] max-w-[100vw] -translate-x-full flex-col rounded-r-md border-r border-[#eceef3] bg-white p-px opacity-0 blur-md transition-all duration-300 ease-in-out"
  >
    <div class="grid h-full grid-rows-[minmax(0,1fr)] rounded-r-md bg-white">
      <div class="flex h-full flex-col overflow-hidden">
        <DesktopSidebar
          activeSection={activeSection}
          dashboardAuth={dashboardAuth}
          permissions={permissions}
          orgSlug={orgSlug}
          whitelabeling={whitelabeling}
        />
      </div>
    </div>
  </aside>
</div>

<script is:inline>
  (() => {
    const bindMobileNav = () => {
      const toggle = document.getElementById("mobile-nav-toggle");
      const root = document.getElementById("mobile-nav-root");
      const overlay = document.getElementById("mobile-nav-overlay");
      const sheet = document.getElementById("mobile-nav-sheet");

      if (!(toggle instanceof HTMLButtonElement)) return;
      if (!(root instanceof HTMLDivElement)) return;
      if (!(overlay instanceof HTMLButtonElement)) return;
      if (!(sheet instanceof HTMLElement)) return;
      if (toggle.dataset.navBound === "true") return;

      let closeTimer;

      const reveal = () => {
        root.classList.remove("hidden", "pointer-events-none");
        root.setAttribute("aria-hidden", "false");
        toggle.setAttribute("aria-expanded", "true");
        window.clearTimeout(closeTimer);
        window.requestAnimationFrame(() => {
          overlay.classList.remove("opacity-0", "backdrop-blur-[0px]");
          overlay.classList.add("opacity-100", "backdrop-blur-sm");
          sheet.classList.remove("-translate-x-full", "opacity-0", "blur-md");
          sheet.classList.add("translate-x-0", "opacity-100", "blur-0");
        });
      };

      const conceal = () => {
        toggle.setAttribute("aria-expanded", "false");
        overlay.classList.remove("opacity-100", "backdrop-blur-sm");
        overlay.classList.add("opacity-0", "backdrop-blur-[0px]");
        sheet.classList.remove("translate-x-0", "opacity-100", "blur-0");
        sheet.classList.add("-translate-x-full", "opacity-0", "blur-md");
        window.clearTimeout(closeTimer);
        closeTimer = window.setTimeout(() => {
          root.classList.add("hidden", "pointer-events-none");
          root.setAttribute("aria-hidden", "true");
        }, 280);
      };

      const onToggle = () => {
        if (window.innerWidth >= 1024) return;
        const isOpen = toggle.getAttribute("aria-expanded") === "true";
        if (isOpen) conceal();
        else reveal();
      };

      toggle.addEventListener("click", onToggle);
      overlay.addEventListener("click", conceal);
      root.querySelectorAll("a[href]").forEach((node) => {
        node.addEventListener("click", conceal);
      });
      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape") conceal();
      });
      window.addEventListener("resize", () => {
        if (window.innerWidth >= 1024) conceal();
      });

      toggle.dataset.navBound = "true";
    };

    bindMobileNav();
    document.addEventListener("astro:page-load", bindMobileNav);
    document.addEventListener("astro:after-swap", bindMobileNav);
  })();
</script>
