---
interface Props {
	deploymentsHref: string;
}

const { deploymentsHref } = Astro.props;
---

<section class="nz-project-overview" aria-label="Logs">
	<div class="nz-project-overview__topbar">
		<div class="min-w-0">
			<p class="truncate text-xs font-semibold text-[var(--nz-text)]">Logs</p>
			<p class="mt-1 truncate text-[11px] text-[var(--nz-text-muted)]">
				Deployment and runtime log entry points.
			</p>
		</div>
	</div>
	<div class="nz-project-panel__body space-y-3">
		<div class="nz-project-log-grid">
			<div class="nz-project-log-card">
				<p class="font-medium text-[var(--nz-text)]">Deployments</p>
				<p>Build and deploy history across project services.</p>
			</div>
			<div class="nz-project-log-card">
				<p class="font-medium text-[var(--nz-text)]">Runtime logs</p>
				<p>Open a service to inspect container logs and terminals.</p>
			</div>
		</div>
		<a
			href={deploymentsHref}
			class="inline-flex h-7 items-center justify-center rounded-md border border-[var(--nz-border)] bg-[var(--nz-bg-muted)] px-2 text-xs font-medium text-[var(--nz-text)] hover:bg-[var(--nz-bg-hover)]"
		>
			Open deployments
		</a>
	</div>
</section>
