---
import { IS_COMMUNITY } from "@/lib/branding";

interface DnsZoneOption {
	dnsZoneId: string;
	name: string;
}

interface ServiceLink {
	name: string;
	type: string;
	href: string;
	status?: string;
	serverId?: string | null;
	domains?: Array<{
		domainId: string;
		host: string;
		https: boolean;
		managedByNearzero?: boolean;
		dnsZoneId?: string | null;
		dnsRecordId?: string | null;
	}>;
}

interface Props {
	environmentId: string;
	dnsZoneId: string | null;
	dnsZoneName: string | null;
	domainPrefix: string;
	dnsZones: DnsZoneOption[];
	services: ServiceLink[];
}

const {
	environmentId,
	dnsZoneId,
	dnsZoneName,
	domainPrefix,
	dnsZones,
	services,
} = Astro.props;
---

<section class="nz-project-overview" aria-label="Domains">
	<div class="nz-project-overview__topbar">
		<div class="min-w-0">
			<p class="truncate text-xs font-semibold text-[var(--nz-text)]">Domains</p>
			<p class="mt-1 truncate text-[11px] text-[var(--nz-text-muted)]">
				Bind a managed DNS zone or use platform defaults; attach domains per service.
			</p>
		</div>
	</div>
	<div class="nz-project-panel__body space-y-4">
		<form
			id="nz-project-domains-form"
			class="space-y-3 rounded-md border border-[var(--nz-border)] p-4"
			data-environment-id={environmentId}
		>
			<p class="text-xs font-medium text-[var(--nz-text)]">Environment DNS binding</p>
			<label class="grid gap-1">
				<span class="text-[11px] text-[var(--nz-text-muted)]">DNS zone</span>
				<select
					id="nz-project-domains-zone"
					name="dnsZoneId"
					class="rounded-md border border-[var(--nz-border)] bg-[var(--nz-bg)] px-2 py-1.5 text-xs"
				>
					<option value="">None (manual / platform apex only)</option>
					{
						dnsZones.map((zone) => (
							<option value={zone.dnsZoneId} selected={zone.dnsZoneId === dnsZoneId}>
								{zone.name}
							</option>
						))
					}
				</select>
			</label>
			<label class="grid gap-1">
				<span class="text-[11px] text-[var(--nz-text-muted)]">Domain prefix (optional)</span>
				<input
					id="nz-project-domains-prefix"
					name="domainPrefix"
					type="text"
					value={domainPrefix}
					placeholder="apps"
					class="rounded-md border border-[var(--nz-border)] bg-[var(--nz-bg)] px-2 py-1.5 text-xs"
				/>
			</label>
			<p id="nz-project-domains-status" class="text-[11px] text-[var(--nz-text-muted)]">
				{
					dnsZoneName
						? `Active zone: ${dnsZoneName}`
						: "No org zone bound — bind a zone here or use platform auto URLs."
				}
			</p>
			<ul class="list-disc space-y-1 pl-4 text-[11px] text-[var(--nz-text-muted)]">
				<li>
					<a href="/dashboard/domains" class="underline underline-offset-2 hover:text-[var(--nz-text)]">
						Infrastructure → Domains
					</a>
					{" "}
					— manage hostnames, DNS zones, and certificates centrally
				</li>
				{
					IS_COMMUNITY ? (
						<li>
							<a href="/dashboard/about-nearzero" class="underline underline-offset-2 hover:text-[var(--nz-text)]">
								About Nearzero
							</a>
							{" "}
							— platform routing and managed DNS guidance
						</li>
					) : null
				}
				<li>
					Optional: set <code>NEARZERO_PLATFORM_DOMAIN</code> for wildcard platform URLs
				</li>
			</ul>
			<p class="text-[11px] text-[var(--nz-text-muted)]">
				Org-wide DNS and hostname management lives in{" "}
				<a href="/dashboard/domains" class="underline underline-offset-2 hover:text-[var(--nz-text)]">
					Infrastructure → Domains
				</a>
				.
			</p>
			<div class="flex justify-end">
				<button
					type="submit"
					id="nz-project-domains-save"
					class="rounded-md bg-[var(--nz-text)] px-3 py-1.5 text-xs font-medium text-[var(--nz-bg)]"
				>
					Save binding
				</button>
			</div>
		</form>
		<p class="text-xs text-[var(--nz-text-muted)]">
			Domains attach to application and compose services. Managed records use the service server when one is selected.
		</p>
		{
			services.length > 0 ? (
				<div class="rounded-md border border-[var(--nz-border)]">
					<table class="w-full border-collapse text-xs">
						<thead class="border-b border-[var(--nz-border)] bg-[var(--nz-bg-muted)]">
							<tr>
								<th class="px-3 py-2 text-left font-medium">Service</th>
								<th class="px-3 py-2 text-left font-medium">Type</th>
								<th class="px-3 py-2 text-left font-medium">Host</th>
								<th class="px-3 py-2 text-left font-medium">Mode</th>
								<th class="px-3 py-2 text-left font-medium">Target</th>
								<th class="px-3 py-2 text-left font-medium">Status</th>
								<th class="px-3 py-2 text-right font-medium">Manage</th>
							</tr>
						</thead>
						<tbody>
							{
								services.flatMap((service) => {
									const rows = service.domains?.length
										? service.domains
										: [null];
									return rows.map((domain) => {
										const mode =
											domain?.managedByNearzero
												? "Managed"
												: domain
													? "Manual"
													: "Not assigned";
										const target = service.serverId ? "Server" : "Web server";
										const status =
											domain?.managedByNearzero && !domain.dnsRecordId
												? "Pending DNS"
												: domain
													? "Ready"
													: service.status ?? "idle";
										return (
											<tr class="border-b border-[var(--nz-border)] last:border-b-0">
												<td class="px-3 py-2 font-medium text-[var(--nz-text)]">{service.name}</td>
												<td class="px-3 py-2 text-[var(--nz-text-muted)]">{service.type}</td>
												<td class="px-3 py-2 text-[var(--nz-text)]">
													{domain ? (
														<a
															href={`${domain.https ? "https" : "http"}://${domain.host}`}
															target="_blank"
															rel="noopener noreferrer"
															class="underline-offset-2 hover:underline"
														>
															{domain.host}
														</a>
													) : (
														<span class="text-[var(--nz-text-muted)]">—</span>
													)}
												</td>
												<td class="px-3 py-2 text-[var(--nz-text-muted)]">{mode}</td>
												<td class="px-3 py-2 text-[var(--nz-text-muted)]">{target}</td>
												<td class="px-3 py-2 text-[var(--nz-text-muted)]">{status}</td>
												<td class="px-3 py-2 text-right">
													<a
														href={service.href}
														class="text-[var(--nz-text)] underline-offset-2 hover:underline"
													>
														Manage
													</a>
												</td>
											</tr>
										);
									});
								})
							}
						</tbody>
					</table>
				</div>
			) : (
				<p class="text-xs text-[var(--nz-text-muted)]">No services in this environment yet.</p>
			)
		}
	</div>
</section>
