---
import { buttonClass, cardClass } from "./demoShared";

interface Props {
  rows: Array<{ title: string; copy: string }>;
}

const { rows } = Astro.props;
---

<div class="grid gap-px lg:grid-cols-3">
  {rows.map((row) => (
    <div class={cardClass}>
      <p class="text-sm font-medium text-[#111827]">{row.title}</p>
      <p class="mt-3 text-xs leading-6 text-[#6b7280]">{row.copy}</p>
      <a class={`${buttonClass} mt-4`} href="/">
        Open
      </a>
    </div>
  ))}
</div>
