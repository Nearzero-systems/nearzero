---
import Button from "@/components/ui/Button.astro";
import DockerTerminalShell from "@/components/dashboard/terminal/DockerTerminalShell.astro";
import { createServerTrpcClient } from "@/lib/server-api";

interface Props {
	request: Request;
	composeId: string;
}

const { request, composeId } = Astro.props;
const api = createServerTrpcClient(request) as any;

let row: any = null;
let permissions: any = null;
let githubProviders: any[] = [];

try {
	[row, permissions, githubProviders] = await Promise.all([
		api.compose.one.query({ composeId }),
		api.user.getPermissions.query(),
		api.github.githubProviders.query(),
	]);
} catch {
	row = null;
}

const projId = row?.environment?.project?.projectId ?? "";
const envId = row?.environmentId ?? "";
const deploymentsTabHref =
	projId && envId
		? `/dashboard/project/${projId}/environment/${envId}/services/compose/${composeId}?tab=deployments`
		: "";

const appName = row?.appName ?? "";
const serviceName = row?.name ?? appName ?? "Compose";
const serverId = row?.serverId ?? "";
const composeType = row?.composeType ?? "docker-compose";
const composeStatus = row?.composeStatus ?? "idle";
const sourceType = row?.sourceType ?? "github";
const hasGitProviderAccess = row?.hasGitProviderAccess !== false;
const canDeploy = permissions?.deployment?.create ?? false;
const canUpdateService = permissions?.service?.create ?? false;
const showStart = canDeploy && composeType === "docker-compose" && composeStatus === "idle";
const showStop = canDeploy && !showStart;
const showUnauthorized = row && !hasGitProviderAccess && sourceType !== "raw";
const hasCompose = Boolean(composeId && row);
const composeTriggerIsTag = row?.triggerType === "tag";
const composeTriggerIsPush = !composeTriggerIsTag;

const inputClass =
	"flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2";
const labelClass = "text-sm font-medium";
const tabBtnClass =
	"rounded-none border-b-2 border-b-transparent px-1 pb-2 text-sm font-medium text-muted-foreground hover:text-foreground";
---

<div
	class="nz-dashboard-content min-h-0 w-full"
	data-compose-action-root={hasCompose ? "1" : undefined}
	data-compose-id={hasCompose ? composeId : undefined}
	data-compose-deploy-href={hasCompose ? deploymentsTabHref : undefined}
	data-compose-app-name={hasCompose ? appName : undefined}
	data-compose-server-id={hasCompose ? serverId : undefined}
	data-compose-type={hasCompose ? composeType : undefined}
	data-source-type={hasCompose ? sourceType : undefined}
	data-has-git-provider-access={hasCompose && hasGitProviderAccess ? "1" : "0"}
	data-can-update-service={hasCompose && canUpdateService ? "1" : "0"}
>
	{
		!composeId ? (
			<p class="px-2 py-4 text-xs text-[#6b7280]">Missing compose id.</p>
		) : !row ? (
			<p class="px-2 py-4 text-xs text-[#6b7280]">Compose not found.</p>
		) : (
			<div class="flex w-full flex-col gap-6">
				<div class="rounded-xl border bg-background text-card-foreground shadow-sm">
					<div class="flex flex-col space-y-1.5 p-6 pt-8">
						<div class="flex flex-row flex-wrap justify-between gap-2">
							<h3 class="text-xl font-semibold leading-none tracking-tight">Deploy Settings</h3>
							<span class="inline-flex items-center rounded-full border border-transparent bg-primary px-2.5 py-0.5 text-xs font-semibold text-primary-foreground">
								{composeType === "docker-compose" ? "Compose" : "Stack"}
							</span>
						</div>
						<p class="text-sm text-muted-foreground">Create a compose file to deploy your compose</p>
					</div>
					<div class="flex flex-col gap-4 border-t px-6 pb-8 pt-6">
						<div class="flex w-full flex-row flex-wrap gap-4">
							{
								canDeploy ? (
									<>
										<Button variant="default" disabled={composeStatus === "running"} id="nz-compose-deploy-btn" type="button" class="nz-compose-act-btn flex items-center gap-1.5" data-act="deploy">Deploy</Button>
										<Button variant="secondary" disabled={composeStatus === "running"} id="nz-compose-redeploy-btn" type="button" class="nz-compose-act-btn flex items-center gap-1.5" data-act="redeploy" data-compose-busy="1">Reload</Button>
									</>
								) : null
							}
							{
								showStart ? (
									<Button variant="secondary" id="nz-compose-start-btn" type="button" class="nz-compose-act-btn flex items-center gap-1.5" data-act="start" data-compose-ss="1">Start</Button>
								) : showStop ? (
									<Button variant="destructive" id="nz-compose-stop-btn" type="button" class="nz-compose-act-btn flex items-center gap-1.5" data-act="stop" data-compose-ss="1">Stop</Button>
								) : null
							}
							<Button variant="outline" type="button" id="nz-compose-terminal-open" class="flex items-center gap-1.5">Open Terminal</Button>
							{
								canUpdateService ? (
									<div class="flex flex-row items-center gap-2 rounded-md border px-4 py-2">
										<span class="text-sm font-medium">Autodeploy</span>
										<input type="checkbox" id="nz-compose-autodeploy" class="h-4 w-4" checked={Boolean(row.autoDeploy)} aria-label="Toggle autodeploy" />
									</div>
								) : null
							}
						</div>
					</div>
				</div>

				{
					showUnauthorized ? (
						<div class="rounded-xl border bg-background shadow-sm">
							<div class="p-6 space-y-4">
								<h3 class="text-xl font-semibold">Provider</h3>
								<p class="text-sm text-muted-foreground">Unauthorized git provider connection</p>
								<Button type="button" variant="secondary" id="nz-compose-disconnect-git">Disconnect Repository</Button>
							</div>
						</div>
					) : (
						<div class="rounded-xl border bg-background shadow-sm" id="nz-compose-provider-root">
							<div class="flex flex-col space-y-1.5 p-6">
								<div class="flex flex-wrap items-center justify-between gap-2">
									<div>
										<h3 class="text-xl font-semibold">Provider</h3>
										<p class="text-sm text-muted-foreground">Select the source of your code</p>
									</div>
									<Button type="button" variant="outline" id="nz-compose-preview-open">Preview Compose</Button>
								</div>
							</div>
							<div class="border-t p-6 pt-4">
								<div class="mb-4 flex flex-wrap gap-4 overflow-auto">
									{["github", "gitlab", "bitbucket", "gitea", "git", "raw"].map((tab) => (
										<button type="button" class={tabBtnClass} data-compose-provider-tab={tab}>{tab === "raw" ? "Raw" : tab.charAt(0).toUpperCase() + tab.slice(1)}</button>
									))}
								</div>
								<div data-compose-provider-panel="github" class={sourceType === "github" ? "" : "hidden"}>
									{githubProviders.length === 0 ? (
										<p class="py-8 text-center text-sm text-muted-foreground">Configure GitHub in Settings first.</p>
									) : (
										<form id="nz-compose-github-form" class="grid gap-4 md:grid-cols-2">
											<label class={`${labelClass} md:col-span-2 grid gap-1`}>Github Account
												<select id="nz-compose-github-account" class={inputClass} required>
													{githubProviders.map((p: any) => (
														<option value={p.githubId} selected={p.githubId === row.githubId}>{p.gitProvider?.name}</option>
													))}
												</select>
											</label>
											<label class={`${labelClass} md:col-span-2 grid gap-1`}>Repository
												<select id="nz-compose-github-repo" class={inputClass} required></select>
											</label>
											<label class={`${labelClass} grid gap-1`}>Branch
												<select id="nz-compose-github-branch" class={inputClass} required></select>
											</label>
											<label class={`${labelClass} grid gap-1`}>Compose Path
												<input id="nz-compose-github-compose-path" class={inputClass} value={row.composePath ?? "./docker-compose.yml"} />
											</label>
											<label class={`${labelClass} md:col-span-2 grid gap-1`}>Trigger Type
												<select id="nz-compose-github-trigger" class={inputClass}>
													<option value="push" selected={composeTriggerIsPush}>On Push</option>
													<option value="tag" selected={composeTriggerIsTag}>On Tag</option>
												</select>
											</label>
											<label class="flex items-center gap-2 md:col-span-2">
												<input type="checkbox" id="nz-compose-github-submodules" checked={Boolean(row.enableSubmodules)} />
												<span class="text-sm">Enable Submodules</span>
											</label>
											<div class="md:col-span-2 flex justify-end"><Button type="submit" id="nz-compose-github-save">Save</Button></div>
										</form>
									)}
								</div>
								<div data-compose-provider-panel="raw" class={sourceType === "raw" ? "" : "hidden"}>
									<form id="nz-compose-raw-form" class="space-y-4">
										<label class={`${labelClass} grid gap-1`}>Compose file (YAML)
											<textarea id="nz-compose-raw-file" class={`${inputClass} min-h-[320px] font-mono`} required>{row.composeFile ?? ""}</textarea>
										</label>
										<div class="flex justify-end"><Button type="submit" id="nz-compose-raw-save">Save</Button></div>
									</form>
								</div>
								{["gitlab", "bitbucket", "gitea", "git"].map((tab) => (
									<div data-compose-provider-panel={tab} class={sourceType === tab ? "" : "hidden"}>
										<p class="py-4 text-sm text-muted-foreground">Use GitHub or Raw tabs, or configure {tab} providers in Settings.</p>
									</div>
								))}
							</div>
						</div>
					)
				}

				<div class="rounded-xl border bg-background shadow-sm" id="nz-compose-logs-section">
					<div class="flex flex-col space-y-1.5 p-6">
						<h3 class="text-xl font-semibold">Logs</h3>
						<p class="text-sm text-muted-foreground">Watch the logs of the application in real time</p>
					</div>
					<div class="space-y-4 border-t p-6 pt-4">
						<div class="flex flex-row flex-wrap items-center justify-between gap-2">
							<label class={`${labelClass} grid flex-1 gap-1`}>Container
								<select id="nz-compose-logs-container" class={inputClass}></select>
							</label>
							{
								composeType === "stack" ? (
									<label class="flex items-center gap-2 text-sm">
										<span class="text-muted-foreground">Swarm</span>
										<input type="checkbox" id="nz-compose-logs-runtype" aria-label="Use native containers instead of swarm" />
										<span class="text-muted-foreground">Native</span>
									</label>
								) : null
							}
						</div>
						<pre id="nz-compose-logs-body" class="h-[360px] overflow-auto rounded-md border bg-black p-4 text-xs font-mono text-green-400 whitespace-pre-wrap">Select a container to view logs.</pre>
					</div>
				</div>

				<div class="rounded-xl border bg-background shadow-sm" id="nz-compose-containers-root">
					<div class="flex flex-row items-center justify-between p-6">
						<div>
							<h3 class="text-xl font-semibold">Containers</h3>
							<p class="text-sm text-muted-foreground">Inspect each container in this compose and run basic lifecycle actions.</p>
						</div>
						<Button type="button" variant="outline" id="nz-compose-containers-refresh">Refresh</Button>
					</div>
					<div class="border-t px-6 pb-6">
						<div class="overflow-auto rounded-md border">
							<table class="w-full text-sm">
								<thead class="border-b">
									<tr>
										<th class="p-4 text-left font-medium text-muted-foreground">Name</th>
										<th class="p-4 text-left font-medium text-muted-foreground">State</th>
										<th class="p-4 text-left font-medium text-muted-foreground">Status</th>
										<th class="p-4 text-left font-medium text-muted-foreground">Container ID</th>
										<th class="p-4 text-right font-medium text-muted-foreground" />
									</tr>
								</thead>
								<tbody id="nz-compose-containers-tbody" />
							</table>
						</div>
					</div>
				</div>

				<dialog id="nz-compose-act-dialog" class="relative w-[calc(100%-2rem)] max-w-md rounded-lg border bg-background shadow-lg backdrop:bg-black/50">
					<div class="p-6 pt-10">
						<button type="button" class="absolute right-4 top-4" aria-label="Close" data-close-compose-act>✕</button>
						<p id="nz-compose-act-title" class="text-lg font-semibold" />
						<p id="nz-compose-act-desc" class="mt-3 text-sm text-muted-foreground" />
						<p id="nz-compose-act-error" class="mt-2 hidden text-xs text-red-600" />
						<div class="mt-6 grid grid-cols-2 gap-2">
							<Button variant="outline" type="button" id="nz-compose-act-cancel">Cancel</Button>
							<Button variant="default" type="button" id="nz-compose-act-run">Continue</Button>
						</div>
					</div>
				</dialog>

				<DockerTerminalShell
					id="nz-compose-terminal-dialog"
					hostId="nz-compose-terminal-host"
					containerSelectId="nz-compose-terminal-container"
					shellSelectId="nz-compose-terminal-way"
					closeButtonId="nz-compose-terminal-close-request"
					sectionLabel="compose"
					nameLabel={serviceName}
					defaultShell="bash"
				/>

				<dialog id="nz-compose-terminal-close-dialog" class="relative w-[calc(100%-2rem)] max-w-md rounded-lg border bg-background shadow-lg backdrop:bg-black/50">
					<div class="p-6">
						<p class="text-lg font-semibold">Are you sure you want to close the terminal?</p>
						<div class="mt-6 flex justify-end gap-2">
							<Button type="button" variant="outline" id="nz-compose-terminal-close-cancel">Cancel</Button>
							<Button type="button" id="nz-compose-terminal-close-confirm">Confirm</Button>
						</div>
					</div>
				</dialog>

				<dialog id="nz-compose-preview-dialog" class="relative w-[calc(100%-2rem)] max-w-6xl rounded-lg border bg-background shadow-lg backdrop:bg-black/50">
					<div class="p-6 max-h-[85vh] overflow-y-auto">
						<button type="button" class="absolute right-4 top-4" data-close-compose-preview aria-label="Close">✕</button>
						<h2 class="text-lg font-semibold">Converted Compose</h2>
						<pre id="nz-compose-preview-body" class="mt-4 overflow-auto rounded-md border bg-muted/50 p-4 text-xs font-mono whitespace-pre-wrap" />
					</div>
				</dialog>
			</div>
		)
	}
</div>

<script>
	import { bootComposeDashboard } from "@/scripts/compose-dashboard";
	bootComposeDashboard();
	document.addEventListener("astro:page-load", bootComposeDashboard);
	document.addEventListener("astro:after-swap", bootComposeDashboard);
</script>
