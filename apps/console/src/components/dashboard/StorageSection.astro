---
import { cardClass } from "./demoShared";

interface Props {
  glacierBucketRows: any[];
}

const { glacierBucketRows } = Astro.props;
---

<div class="grid gap-px lg:grid-cols-2">
  {glacierBucketRows.map((bucket) => (
    <div class={cardClass}>
      <p class="text-xs text-[#6b7280]">
        Bucket
      </p>
      <h2 class="mt-3 text-sm font-medium text-[#111827]">{bucket.name}</h2>
      <div class="mt-4 grid gap-px sm:grid-cols-2">
        <div class="rounded-md bg-[#f7f7f8] px-3 py-3">
          <p class="text-xs text-[#6b7280]">
            Objects
          </p>
          <p class="mt-2 text-sm font-medium text-[#111827]">
            {bucket.objectCount}
          </p>
        </div>
        <div class="rounded-md bg-[#f7f7f8] px-3 py-3">
          <p class="text-xs text-[#6b7280]">
            Footprint
          </p>
          <p class="mt-2 text-sm font-medium text-[#111827]">
            {bucket.sizeLabel}
          </p>
        </div>
      </div>
    </div>
  ))}
</div>
