---
import MonitoringDashboard from "@/components/dashboard/monitoring/MonitoringDashboard.astro";
import PublicDomainDialog from "@/components/dashboard/settings/web-server/PublicDomainDialog.astro";
import Button from "@/components/ui/Button.astro";
import { createServerTrpcClient } from "@/lib/server-api";

let serverIp = "";
let publicHost = "";
let httpsEnabled = false;
let letsEncryptEmail = "";
let canConfigureDomain = false;
const nearzeroVersion = "0.0.1";
let releaseTag = "";

const api = createServerTrpcClient(Astro.request) as {
	settings: {
		getWebServerSettings: {
			query: () => Promise<{
				serverIp?: string | null;
				host?: string | null;
				https?: boolean;
				letsEncryptEmail?: string | null;
			}>;
		};
		getReleaseTag: { query: () => Promise<string> };
	};
	user: {
		get: { query: () => Promise<{ role?: string | null } | null> };
	};
};
try {
	const [webServerSettings, tag, currentMember] = await Promise.all([
		api.settings.getWebServerSettings.query(),
		api.settings.getReleaseTag.query(),
		api.user.get.query(),
	]);
	serverIp = webServerSettings?.serverIp?.trim() ?? "";
	publicHost = webServerSettings?.host?.trim() ?? "";
	httpsEnabled = Boolean(webServerSettings?.https);
	letsEncryptEmail = webServerSettings?.letsEncryptEmail?.trim() ?? "";
	canConfigureDomain =
		currentMember?.role === "owner" || currentMember?.role === "admin";
	releaseTag = tag ?? "";
} catch {
	/* partial ok */
}

const versionLabel =
	releaseTag === "nightly" || releaseTag === "feature"
		? `${nearzeroVersion} (${releaseTag})`
		: nearzeroVersion;
---

<div
	id="nz-about-nearzero-root"
	class="nz-about-nearzero w-full min-w-0"
	data-public-host={publicHost}
	data-letsencrypt-email={letsEncryptEmail}
>
	<section class="nz-about-nearzero__meta" aria-label="Platform information">
		<dl class="nz-about-nearzero__grid">
			<div class="nz-about-nearzero__item">
				<dt>Version</dt>
				<dd class="nz-about-nearzero__value">{versionLabel || "—"}</dd>
			</div>
			<div class="nz-about-nearzero__item">
				<dt>Server IP</dt>
				<dd class="nz-about-nearzero__value nz-about-nearzero__value--ip">
					<span id="nz-ws-server-ip">{serverIp || "—"}</span>
					{
						serverIp ? (
							<button
								type="button"
								id="nz-ws-copy-ip"
								class="nz-about-nearzero__copy"
								aria-label="Copy server IP"
								title="Copy server IP"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="14"
									height="14"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									aria-hidden="true"
								>
									<rect width="14" height="14" x="8" y="8" rx="2" ry="2" />
									<path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
								</svg>
							</button>
						) : null
					}
				</dd>
			</div>
			<div class="nz-about-nearzero__item">
				<dt>Public URL</dt>
				<dd class="nz-about-nearzero__value nz-about-nearzero__value--public">
					<span>
						{
							publicHost
								? `${httpsEnabled ? "https" : "http"}://${publicHost}`
								: "Not configured"
						}
					</span>
					{
						canConfigureDomain ? (
							<Button type="button" variant="outline" id="nz-ws-domain-open">
								{publicHost ? "Change domain" : "Configure domain"}
							</Button>
						) : null
					}
				</dd>
			</div>
		</dl>
	</section>

	<section
		id="metrics"
		class="nz-about-nearzero__metrics scroll-mt-6"
	>
		<MonitoringDashboard />
	</section>
</div>

{canConfigureDomain ? <PublicDomainDialog serverIp={serverIp} /> : null}

<script>
	import { mountAboutNearzeroDashboard } from "@/scripts/mount-about-nearzero";
	import { mountMonitoringDashboard } from "@/scripts/mount-monitoring-dashboard";
	mountAboutNearzeroDashboard();
	mountMonitoringDashboard();
</script>
