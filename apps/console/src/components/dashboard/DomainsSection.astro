---
import { buttonClass, cardClass, statusPillClass } from "./demoShared";

interface Props {
  domainRows: any[];
}

const { domainRows } = Astro.props;
---

<div class={cardClass}>
  <div class="flex flex-wrap items-center justify-between gap-2">
    <p class="text-xs text-[#6b7280]">
      Domain routing
    </p>
    <a class={buttonClass} href="/">
      Connect account
    </a>
  </div>
  <div class="mt-4 divide-y divide-[#eceef3]">
    {domainRows.map((domain) => (
      <div class="flex flex-col gap-3 py-4 md:flex-row md:items-center md:justify-between">
        <div>
          <p class="text-sm font-medium text-[#111827]">{domain.domain}</p>
          <p class="mt-2 text-xs text-[#6b7280]">
            Serving {domain.projectName} · deployment {domain.deploymentId || "pending"}
          </p>
        </div>
        <span class={`rounded-md border px-2 py-1 text-xs ${statusPillClass(domain.status)}`}>
          {domain.status}
        </span>
      </div>
    ))}
  </div>
</div>
