---
import { cardClass } from "./demoShared";

interface Props {
  rows: Array<{ name: string; pending: number; consumers: number; throughput: string }>;
}

const { rows } = Astro.props;
---

<div class="grid gap-px lg:grid-cols-3">
  {rows.map((row) => (
    <div class={cardClass}>
      <p class="text-xs text-[#6b7280]">
        Queue
      </p>
      <h2 class="mt-3 text-sm font-medium text-[#111827]">{row.name}</h2>
      <div class="mt-4 space-y-3 text-xs text-[#6b7280]">
        <div class="flex items-center justify-between rounded-md bg-[#f7f7f8] px-3 py-3">
          <span>Pending</span>
          <span class="text-[#111827]">{row.pending}</span>
        </div>
        <div class="flex items-center justify-between rounded-md bg-[#f7f7f8] px-3 py-3">
          <span>Consumers</span>
          <span class="text-[#111827]">{row.consumers}</span>
        </div>
        <div class="flex items-center justify-between rounded-md bg-[#f7f7f8] px-3 py-3">
          <span>Throughput</span>
          <span class="text-[#111827]">{row.throughput}</span>
        </div>
      </div>
    </div>
  ))}
</div>
