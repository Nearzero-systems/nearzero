---
interface Props {
	label: string;
}

const { label } = Astro.props;
---

<span class="nz-app-setting-hint" data-nz-setting-hint>
	<span
		class="nz-app-setting-hint__btn"
		tabindex="0"
		role="img"
		aria-label={label}
	>
		<svg
			xmlns="http://www.w3.org/2000/svg"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true"
		>
			<circle cx="12" cy="12" r="10"></circle>
			<path d="M12 16v-4"></path>
			<path d="M12 8h.01"></path>
		</svg>
	</span>
	<span class="nz-app-setting-hint__tooltip" role="tooltip">{label}</span>
</span>
