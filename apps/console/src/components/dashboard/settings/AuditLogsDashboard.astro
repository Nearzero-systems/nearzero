---
import { format } from "date-fns";
import Button from "@/components/ui/Button.astro";
import SettingsEmptyState from "@/components/dashboard/settings/SettingsEmptyState.astro";
import { bootstrapSettingsDashboardPage } from "@/components/dashboard/settings/settingsDashboardBootstrap";
import { settingsDashboardGates } from "@/components/dashboard/settings/settingsDashboardGates";
import { ST } from "@/lib/settings-hub-ui";
import { createServerTrpcClient } from "@/lib/server-api";

const bootstrap = await bootstrapSettingsDashboardPage(Astro.request, {
	gate: settingsDashboardGates.auditLogs,
});

const loadFailed = bootstrap.ok === false && bootstrap.reason === "load-failed";
const forbidden = bootstrap.ok === false && bootstrap.reason === "forbidden";

let haveValidLicense = false;
let initialLogs: any[] = [];
let initialTotal = 0;

if (bootstrap.ok) {
	const api = createServerTrpcClient(Astro.request) as any;
	try {
		haveValidLicense = await api.licenseKey.haveValidLicenseKey.query();
		if (haveValidLicense) {
			const data = await api.auditLog.all.query({ limit: 50, offset: 0 });
			initialLogs = data?.logs ?? [];
			initialTotal = data?.total ?? 0;
		}
	} catch {
		haveValidLicense = false;
	}
}

const ACTION_LABELS: Record<string, string> = {
	create: "Created", update: "Updated", delete: "Deleted", deploy: "Deployed",
	cancel: "Cancelled", redeploy: "Redeployed", login: "Login", logout: "Logout",
};
const RESOURCE_LABELS: Record<string, string> = {
	project: "Project", service: "Service", environment: "Environment", deployment: "Deployment",
	user: "User", customRole: "Custom Role", domain: "Domain", certificate: "Certificate",
	registry: "Registry", server: "Server", sshKey: "SSH Key", gitProvider: "Git Provider",
	notification: "Notification", settings: "Settings", session: "Session",
};

function parseAuditMetadata(value: unknown) {
	if (!value || typeof value !== "string") return null;
	try {
		return JSON.parse(value) as { actorType?: string };
	} catch {
		return null;
	}
}

function auditActorLabel(log: { userEmail?: string | null; metadata?: string | null }) {
	return parseAuditMetadata(log.metadata)?.actorType === "agent"
		? "Agent"
		: log.userEmail;
}

function auditRoleLabel(log: { userRole?: string | null; metadata?: string | null }) {
	return parseAuditMetadata(log.metadata)?.actorType === "agent"
		? "agent"
		: log.userRole;
}
---

<div class="w-full">
	{
		loadFailed ? (
			<div class="min-h-[45vh] flex flex-col items-center justify-center gap-2 text-center text-xs text-muted-foreground p-10"><span>Could not load this page.</span></div>
		) : forbidden ? (
			<div class="min-h-[45vh] flex flex-col items-center justify-center gap-3 text-center text-xs text-muted-foreground px-10">
				<span>You do not have access to this section.</span>
				<a href="/dashboard/home" class="text-xs font-medium text-foreground underline-offset-4 hover:underline">Back to dashboard</a>
			</div>
		) : (
			<div class="w-full nz-dashboard-content" id="nz-audit-logs-root" data-have-license={haveValidLicense ? "1" : "0"}>
					{
							!haveValidLicense ? (
								<SettingsEmptyState message="Audit logs are available with Nearzero Enterprise. Activate a license to track every action across your organization." />
							) : (
								<div class={ST.panel}>
									<div class={ST.filterBar}>
										<input
											id="nz-audit-search"
											type="search"
											placeholder="Search by user email or resource name"
											class={ST.filterSearch}
										/>
										<select id="nz-audit-action" class={ST.filterSelect}>
											<option value="">All actions</option>
											{Object.entries(ACTION_LABELS).map(([v, l]) => <option value={v}>{l}</option>)}
										</select>
										<select id="nz-audit-resource-type" class={ST.filterSelect}>
											<option value="">All resources</option>
											{Object.entries(RESOURCE_LABELS).map(([v, l]) => <option value={v}>{l}</option>)}
										</select>
										<select id="nz-audit-page-size" class={ST.filterSelect}>
											<option value="25">25</option>
											<option value="50" selected>50</option>
											<option value="100">100</option>
											<option value="200">200</option>
										</select>
									</div>
									<div class={ST.tableWrap}>
										<table class={ST.table}>
											<thead class={ST.thead}>
												<tr>
													<th class={ST.th}>Date</th>
													<th class={ST.th}>User</th>
													<th class={ST.th}>Action</th>
													<th class={ST.th}>Resource</th>
													<th class={ST.th}>Name</th>
													<th class={ST.th}>Role</th>
													<th class={ST.th}>Metadata</th>
												</tr>
											</thead>
											<tbody id="nz-audit-tbody">
													{
														initialLogs.map((log) => (
															<tr class={ST.tr}>
																<td class={ST.tdMuted}>{format(new Date(log.createdAt), "MMM d, yyyy HH:mm")}</td>
																<td class={ST.td}>{auditActorLabel(log)}</td>
																<td class={ST.td}>{ACTION_LABELS[log.action] ?? log.action}</td>
																<td class={`${ST.td} text-muted-foreground`}>{RESOURCE_LABELS[log.resourceType] ?? log.resourceType}</td>
																<td class={`${ST.td} font-medium`}>{log.resourceName ?? "—"}</td>
																<td class={`${ST.td} text-muted-foreground capitalize`}>{auditRoleLabel(log)}</td>
																<td class={ST.td}>
																	{log.metadata ? (
																		<button type="button" class="text-xs underline" data-metadata={log.metadata}>View</button>
																	) : "—"}
																</td>
															</tr>
														))
													}
												</tbody>
											</table>
									</div>
									<div class={ST.footer}>
										<span id="nz-audit-total" class={ST.total}>{initialTotal} total</span>
										<div class="flex gap-2">
											<Button type="button" variant="outline" size="sm" id="nz-audit-prev">Previous</Button>
											<Button type="button" variant="outline" size="sm" id="nz-audit-next">Next</Button>
										</div>
									</div>
								</div>
							)
						}
					<dialog id="nz-audit-metadata-dialog" class="relative w-[calc(100%-2rem)] max-w-lg rounded-lg border bg-background shadow-lg backdrop:bg-black/50">
					<div class="p-6">
						<button type="button" class="absolute right-4 top-4" data-close-metadata aria-label="Close">✕</button>
						<h2 class="text-lg font-semibold">Metadata</h2>
						<pre id="nz-audit-metadata-body" class="mt-4 max-h-[400px] overflow-auto rounded-md border bg-muted/50 p-3 text-xs font-mono whitespace-pre-wrap"></pre>
					</div>
				</dialog>
			</div>
		)
	}
</div>

<script>
	import { bindAuditLogsPage } from "@/scripts/audit-logs-dashboard";

	function boot() {
		bindAuditLogsPage();
	}
	boot();
	document.addEventListener("astro:page-load", boot);
	document.addEventListener("astro:after-swap", boot);
</script>
