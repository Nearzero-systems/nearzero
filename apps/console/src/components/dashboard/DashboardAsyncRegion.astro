---
import type {
	DashboardAsyncParams,
	DashboardAsyncRouteId,
} from "@/lib/dashboard-async-routes";

interface Props {
	routeId: DashboardAsyncRouteId;
	params?: DashboardAsyncParams;
	search?: string;
	orgSlug?: string | null;
	label?: string;
}

const {
	routeId,
	params = {},
	search = "",
	orgSlug = null,
	label = "Loading...",
} = Astro.props;
---

<div
	class="h-full min-h-0 w-full"
	data-nz-dashboard-async
	data-route-id={routeId}
	data-route-params={JSON.stringify(params)}
	data-route-search={search}
	data-org-slug={orgSlug ?? ""}
>
	<div
		class="nz-dashboard-content flex h-full min-h-[45vh] w-full items-center justify-center p-6 text-center text-xs text-[var(--nz-text-muted)]"
		role="status"
		aria-live="polite"
	>
		<div class="grid justify-items-center gap-3">
			<svg
				xmlns="http://www.w3.org/2000/svg"
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				class="size-4 animate-spin"
				aria-hidden="true"
			>
				<path d="M21 12a9 9 0 1 1-6.219-8.56"></path>
			</svg>
			<span>{label}</span>
		</div>
	</div>
</div>

<script>
	import {
		bindDashboardSidebarNavigation,
		bootDashboardAsyncRegions,
	} from "@/scripts/dashboard-async-region";

	bindDashboardSidebarNavigation();
	bootDashboardAsyncRegions();
	document.addEventListener("astro:page-load", bootDashboardAsyncRegions);
	document.addEventListener("astro:after-swap", bootDashboardAsyncRegions);
</script>
