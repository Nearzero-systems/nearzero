---
---

<div
	class="nz-monitoring w-full min-w-0"
	id="nz-monitoring-root"
>
	<div id="nz-monitoring-loading" class="nz-monitoring__state">
		<span>Loading metrics...</span>
	</div>
	<div
		id="nz-monitoring-error"
		class="nz-monitoring__state nz-monitoring__state--error hidden"
	>
		<div class="nz-monitoring__error-card">
			<p class="nz-monitoring__error-title">Error fetching metrics</p>
			<p id="nz-monitoring-error-msg" class="nz-monitoring__error-message"></p>
		</div>
	</div>
	<div id="nz-monitoring-content" class="nz-monitoring__content hidden">
		<header class="nz-monitoring__header">
			<div class="nz-monitoring__intro">
				<p class="nz-monitoring__eyebrow">Community monitoring</p>
				<h3 class="nz-monitoring__title">Monitoring</h3>
				<p class="nz-monitoring__description">
					Track host CPU, RAM, and storage usage for this Nearzero install.
				</p>
			</div>
			<div class="nz-monitoring__controls">
				<label class="nz-monitoring__control">
					<span>Data points</span>
					<select id="nz-mon-data-points" class="nz-monitoring__select">
						<option value="50">50 points</option>
						<option value="200">200 points</option>
						<option value="500">500 points</option>
						<option value="all">All points</option>
					</select>
				</label>
				<label class="nz-monitoring__control">
					<span>Refresh</span>
					<select id="nz-mon-refresh" class="nz-monitoring__select">
						<option value="5000">5 seconds</option>
						<option value="10000">10 seconds</option>
						<option value="20000">20 seconds</option>
						<option value="30000">30 seconds</option>
					</select>
				</label>
			</div>
		</header>

		<div class="nz-monitoring__cards">
			<div class="nz-monitoring-card">
				<div class="nz-monitoring-card__label">Uptime</div>
				<p id="nz-mon-uptime" class="nz-monitoring-card__value">—</p>
				<p class="nz-monitoring-card__hint">Current host session</p>
			</div>
			<div class="nz-monitoring-card nz-monitoring-card--meter">
				<div class="nz-monitoring-card__label">CPU Usage</div>
				<p id="nz-mon-cpu" class="nz-monitoring-card__value">—</p>
				<div class="nz-monitoring-meter" aria-hidden="true">
					<span id="nz-mon-cpu-bar" class="nz-monitoring-meter__fill"></span>
				</div>
			</div>
			<div class="nz-monitoring-card nz-monitoring-card--meter">
				<div class="nz-monitoring-card__label">RAM Usage</div>
				<p id="nz-mon-mem" class="nz-monitoring-card__value">—</p>
				<div class="nz-monitoring-meter" aria-hidden="true">
					<span id="nz-mon-mem-bar" class="nz-monitoring-meter__fill"></span>
				</div>
			</div>
			<div class="nz-monitoring-card nz-monitoring-card--meter">
				<div class="nz-monitoring-card__label">Storage Usage</div>
				<p id="nz-mon-disk" class="nz-monitoring-card__value">—</p>
				<div class="nz-monitoring-meter" aria-hidden="true">
					<span id="nz-mon-disk-bar" class="nz-monitoring-meter__fill"></span>
				</div>
			</div>
		</div>

		<div class="nz-monitoring-panel">
			<h3 class="nz-monitoring-panel__title">System information</h3>
			<div class="nz-monitoring-panel__grid">
				<div class="nz-monitoring-detail">
					<h4>CPU</h4>
					<p id="nz-mon-cpu-model">—</p>
					<p id="nz-mon-cpu-detail" class="nz-monitoring-detail__muted">—</p>
				</div>
				<div class="nz-monitoring-detail">
					<h4>Operating system</h4>
					<p id="nz-mon-os">—</p>
					<p id="nz-mon-kernel" class="nz-monitoring-detail__muted">—</p>
				</div>
			</div>
		</div>

		<div class="nz-monitoring__charts">
			<div class="nz-monitoring-chart">
				<h4>CPU history</h4>
				<canvas id="nz-mon-cpu-chart"></canvas>
			</div>
			<div class="nz-monitoring-chart">
				<h4>RAM history</h4>
				<canvas id="nz-mon-mem-chart"></canvas>
			</div>
		</div>
	</div>
</div>

<script>
	import { mountMonitoringDashboard } from "@/scripts/mount-monitoring-dashboard";
	mountMonitoringDashboard();
</script>
