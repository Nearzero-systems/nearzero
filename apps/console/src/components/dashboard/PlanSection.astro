---
import {
  getPricingPlanByBillingKey,
  pricingPlans,
  type PricingPlanDefinition,
} from "@nearzero/spec";
import PricingPlanCard from "../pricing/PricingPlanCard.astro";
import { cardClass } from "./demoShared";

interface Props {
  billing: {
    currentPlan: {
      key: string;
      label: string;
      detail: string;
    };
    invoices: Array<{
      invoiceNumber?: string;
      paymentStatusLabel?: string;
      createdAt?: string;
      dashboardInvoiceUrl?: string;
      payInvoiceUrl?: string;
    }>;
  };
}

const { billing } = Astro.props;

const currentPlan =
  getPricingPlanByBillingKey(billing?.currentPlan?.key || "") || pricingPlans[0];

const cardConfigs = pricingPlans.map((plan: PricingPlanDefinition) => {
  const isCurrent = currentPlan?.billingKey === plan.billingKey;
  return {
    plan,
    ctaLabel: isCurrent ? "Active plan" : plan.marketingCtaLabel,
    ctaHref: isCurrent ? "" : "/app?section=plan",
    ctaMethod: isCurrent ? "get" : "post",
    ctaPrimary: !isCurrent,
    ctaDisabled: isCurrent,
    note: "",
    hiddenFields: isCurrent
      ? undefined
      : {
          action: "billing-plan",
          plan: plan.billingKey,
        },
  };
});
---

<section class={`${cardClass} min-h-[calc(100dvh-45px)] overflow-visible`}>
  <div class="min-h-[calc(100dvh-77px)] px-4 py-4 sm:px-6">
    <div class="mx-auto flex h-full w-full max-w-[1100px] flex-col">
      <div class="border-b border-[#eceef3] pb-4">
        <p class="text-xs text-[#6b7280]">Plan</p>
        <h2 class="font-display mt-2 text-[22px] font-semibold tracking-tight text-[#111827] sm:text-[28px]">
          Choose the plan that fits your workspace.
        </h2>
        <p class="mt-3 max-w-3xl text-xs leading-6 text-[#6b7280]">
          Compare Starter, Growth, and Business from one shared pricing system, then move the workspace forward without leaving Nearzero.
        </p>
      </div>

      <div class="mt-4 grid overflow-hidden rounded-md bg-[#eceef3] gap-px lg:min-h-[calc(100dvh-18rem)] lg:grid-cols-3 lg:auto-rows-fr">
        {cardConfigs.map((config: (typeof cardConfigs)[number]) => (
          <div class="min-h-[26rem] bg-white lg:min-h-[calc(100dvh-18rem)]">
            <PricingPlanCard
              plan={config.plan}
              currentBillingKey={currentPlan?.billingKey}
              ctaLabel={config.ctaLabel}
              ctaHref={config.ctaHref}
              ctaMethod={config.ctaMethod as "get" | "post"}
              ctaPrimary={config.ctaPrimary}
              ctaDisabled={config.ctaDisabled}
              hiddenFields={config.hiddenFields}
              note={config.note}
              currentBadgeLabel="Active"
              className="h-full"
            />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
