                preset: String(selectedRepo.preset || "Other").trim(),
                suggestedType: String(selectedRepo.suggestedType || "").trim(),
                root: String(selectedRepo.root || ".").trim() || ".",
                buildCommand: String(selectedRepo.build || "").trim(),
                outputDir: String(selectedRepo.output || "dist").trim() || "dist",
                envEntries: envRows,
              }),
            });
            const data = await res.json().catch(() => ({}));
            if (!res.ok) {
              throw new Error(data.error || `Deploy failed (${res.status})`);
            }
            const depId = String(data.deploymentId || "").trim();
            if (!depId) {
