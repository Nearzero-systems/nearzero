        for (let i = 0; i < configureBranchSelect.options.length; i += 1) {
          if (configureBranchSelect.options[i].value === want) {
            configureBranchSelect.selectedIndex = i;
            found = true;
            break;
          }
        }
        if (!found && want) {
          let exists = false;
          for (let j = 0; j < configureBranchSelect.options.length; j += 1) {
            if (configureBranchSelect.options[j].value === want) {
              exists = true;
              break;
