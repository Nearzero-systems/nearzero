---
import { getFrameworkPresetDefaults, listFrameworkPresetOptions } from "@nearzero/spec";
import { cardClass } from "./demoShared";
import ProjectsConnectView from "./projects/ProjectsConnectView.astro";
import ProjectsConfigureView from "./projects/ProjectsConfigureView.astro";
import ProjectsDeployedView from "./projects/ProjectsDeployedView.astro";
import ProjectsDeployingView from "./projects/ProjectsDeployingView.astro";
import ProjectsImportView from "./projects/ProjectsImportView.astro";
import ProjectsInventoryView from "./projects/ProjectsInventoryView.astro";
import ProjectsLoadingView from "./projects/ProjectsLoadingView.astro";
import { providerAccounts, providerOptions } from "./projects/shared";

interface Props {
  projectRows: any[];
  linkedVcsProviders?: string[];
  githubImportConnected?: boolean;
  gitlabImportConnected?: boolean;
  bitbucketImportConnected?: boolean;
  giteaImportConnected?: boolean;
  projectsInitialView: "connect" | "import" | "inventory";
}

const {
  projectRows,
  linkedVcsProviders = [],
  githubImportConnected = false,
  gitlabImportConnected = false,
  bitbucketImportConnected = false,
  giteaImportConnected = false,
  projectsInitialView,
} = Astro.props;
const linkedVcsAttr = linkedVcsProviders.join(",");
const hasGiteaImportConnection =
  giteaImportConnected || linkedVcsProviders.includes("gitea");
const showConnect = projectsInitialView === "connect";
const showImport = projectsInitialView === "import";
const showInventory = projectsInitialView === "inventory";
const suppressImportToolbarInitially =
  showImport &&
  (githubImportConnected ||
    gitlabImportConnected ||
    bitbucketImportConnected ||
    hasGiteaImportConnection);
const presetDefaults = Object.fromEntries(
  listFrameworkPresetOptions().map((option) => [
    option.id,
    getFrameworkPresetDefaults(option.id),
  ]),
);
const projectLookup = Object.fromEntries(
  projectRows
    .filter((row) => row?.id && row?.repoProvider && row?.repoFull)
    .map((row) => [
      `${String(row.repoProvider).trim().toLowerCase()}:${String(row.repoFull)
        .trim()
        .toLowerCase()}`,
      {
        projectId: String(row.id).trim(),
        projectName: String(row.name || "").trim(),
        branch: String(row.repoBranch || "").trim(),
      },
    ]),
);
---

<section
  class={`${cardClass} min-h-[calc(100dvh-45px)] overflow-visible`}
  data-project-flow-root
  data-has-projects={projectRows.length > 0 ? "true" : "false"}
  data-linked-vcs={linkedVcsAttr}
  data-preset-defaults={JSON.stringify(presetDefaults)}
  data-project-lookup={JSON.stringify(projectLookup)}
  data-github-import-connected={githubImportConnected ? "true" : "false"}
  data-gitlab-import-connected={gitlabImportConnected ? "true" : "false"}
  data-bitbucket-import-connected={bitbucketImportConnected ? "true" : "false"}
  data-gitea-import-connected={hasGiteaImportConnection ? "true" : "false"}
  data-initial-view={projectsInitialView}
>
  <ProjectsConnectView providerOptions={providerOptions} visible={showConnect} />
  <ProjectsLoadingView visible={false} />
  <ProjectsInventoryView projectRows={projectRows} visible={showInventory} />
  <ProjectsImportView
    providerOptions={providerOptions}
    providerAccounts={providerAccounts}
    visible={showImport}
    suppressImportToolbarInitially={suppressImportToolbarInitially}
  />
  <ProjectsConfigureView />
  <ProjectsDeployingView />
  <ProjectsDeployedView />
</section>

<script is:inline>
  (() => {
    const script = document.currentScript;
    const root = script?.previousElementSibling;
    if (!(root instanceof HTMLElement) || root.dataset.bound === "true") {
      return;
    }

    const PRESET_DEFAULTS = JSON.parse(root.dataset.presetDefaults || "{}");
    const PROJECT_LOOKUP = JSON.parse(root.dataset.projectLookup || "{}");

    root.dataset.bound = "true";

    const nzToast = (msg) => {
      document.dispatchEvent(
        new CustomEvent("nz-toast", {
          bubbles: true,
          detail: { message: String(msg || "").trim() },
        }),
      );
    };

    const repoListLoadFailedHtml = () =>
      '<div class="px-4 py-6 text-sm text-[#6b7280]">Couldn\'t load repositories. Try again in a moment.</div>';

    const repoLoadToastForHttp = (errMsg, status) => {
      const lower = String(errMsg || "").toLowerCase();
      if (status === 502 || status === 503 || status === 504) {
        return "The service is temporarily unavailable. Try again shortly.";
      }
      if (/timeout|timed out/i.test(lower)) {
        return "That took too long. Try again.";
      }
      if (/not reachable|could not reach|unreachable/i.test(lower)) {
        return "Can't reach the server right now. Check your connection and try again.";
      }
      return "Something went wrong loading repositories. Try again.";
    };

    const views = Array.from(
      root.querySelectorAll("[data-project-view]"),
    ).filter((node) => node instanceof HTMLElement);

    const providerPanels = Array.from(
      root.querySelectorAll("[data-project-provider-panel]"),
    ).filter((node) => node instanceof HTMLElement);

    const configureProviderLabel = root.querySelector("[data-config-provider-label]");
    const configureRepoFull = root.querySelector("[data-config-repo-full]");
    const configureBranchSelect = root.querySelector("[data-config-branch-select]");
    const configureResolvedSha = root.querySelector("[data-config-resolved-sha]");
    const configureProjectName = root.querySelector("[data-config-project-name]");
    const configurePresetSelect = root.querySelector("[data-config-preset-select]");
    const configureHintsLoading = root.querySelector("[data-config-hints-loading]");
    const configureRoot = root.querySelector("[data-config-root]");
    const configureBuild = root.querySelector("[data-config-build]");
    const configureOutput = root.querySelector("[data-config-output]");
    const configureEnvTbody = root.querySelector("[data-config-env-tbody]");

    const deployProjectName = root.querySelector("[data-deploy-project-name]");
    const deployProviderLabel = root.querySelector("[data-deploy-provider-label]");
    const deployRepoFull = root.querySelector("[data-deploy-repo-full]");
    const deployBranch = root.querySelector("[data-deploy-branch]");
    const deployPreset = root.querySelector("[data-deploy-preset]");

    const deployedProjectName = root.querySelector("[data-deployed-project-name]");
    const deployedProviderLabel = root.querySelector("[data-deployed-provider-label]");
    const deployedRepoFull = root.querySelector("[data-deployed-repo-full]");
    const deployedUrl = root.querySelector("[data-deployed-url]");
    const deployedDeploymentId = root.querySelector("[data-deployed-deployment-id]");
    const deployStatusLine = root.querySelector("[data-deploy-status-line]");
    const deployDeploymentId = root.querySelector("[data-deploy-deployment-id]");
    const deployLogsWrap = root.querySelector("[data-deploy-logs-wrap]");
    const deployLogsLink = root.querySelector("[data-deploy-logs-link]");
    const deployedLogsWrap = root.querySelector("[data-deployed-logs-wrap]");
    const deployedLogsLink = root.querySelector("[data-deployed-logs-link]");

    let deployPollTimer;
    /** Survives full page reloads while on Projects; cleared when deploy finishes or fails. */
    const NZ_DEPLOY_SESSION_KEY = "nz_projects_deploy_track";

    const clearDeploySession = () => {
      try {
        sessionStorage.removeItem(NZ_DEPLOY_SESSION_KEY);
      } catch (_) {}
    };

    const persistDeploySession = (deploymentId) => {
      try {
        sessionStorage.setItem(
          NZ_DEPLOY_SESSION_KEY,
          JSON.stringify({
            deploymentId: String(deploymentId || "").trim(),
            startedAt: Date.now(),
            provider: String(activeProvider || "github").trim() || "github",
            projectId: String(selectedRepo.projectId || "").trim(),
            repo: {
              name: String(selectedRepo.name || "").trim(),
              full: String(selectedRepo.full || "").trim(),
              branch: String(selectedRepo.branch || "main").trim() || "main",
              preset: String(selectedRepo.preset || "Other").trim() || "Other",
              root: String(selectedRepo.root || ".").trim() || ".",
              build: String(selectedRepo.build || "").trim(),
              output: String(selectedRepo.output || "dist").trim() || "dist",
            },
          }),
        );
      } catch (_) {}
    };

    let activeProvider = "github";
    const IMPORT_PROVIDER_KEYS = ["github", "gitlab", "bitbucket", "gitea"];
    const isImportProviderKey = (key) =>
      IMPORT_PROVIDER_KEYS.includes(String(key || "").trim().toLowerCase());
    const providerLabelFallback = (providerKey) => {
      const normalized = String(providerKey || "").trim().toLowerCase();
      if (normalized === "gitlab") return "GitLab";
      if (normalized === "bitbucket") return "Bitbucket";
      if (normalized === "gitea") return "Gitea";
      return "GitHub";
    };
    let selectedRepo = {
      projectId: "",
      name: "",
      full: "",
      branch: "main",
      preset: "Other",
      suggestedType: "",
      root: ".",
      build: "",
      output: "dist",
      envKey: "",
      envValue: "",
      envEntries: [],
      resolvedSha: "",
    };

    const repoLookupKey = (provider, repoFull) =>
      `${String(provider || "github").trim().toLowerCase()}:${String(repoFull || "")
        .trim()
        .toLowerCase()}`;

    const ensureEditableEnvRows = (entries) => {
      const list = Array.isArray(entries)
        ? entries
            .map((entry) => ({
              key: String(entry?.key || "").trim(),
              value: String(entry?.value ?? ""),
            }))
            .filter((entry) => entry.key || entry.value)
        : [];
      if (
        list.length === 0 ||
        String(list[list.length - 1]?.key || "").trim() ||
        String(list[list.length - 1]?.value || "").trim()
      ) {
        list.push({ key: "", value: "" });
      }
      return list;
    };

    const resolveKnownProjectId = () => {
      const key = repoLookupKey(activeProvider, selectedRepo.full);
      const entry = PROJECT_LOOKUP[key];
      return typeof entry?.projectId === "string" ? entry.projectId.trim() : "";
    };

    let configureHintsTimer = null;

    const clearDeployPoll = () => {
      if (deployPollTimer != null) {
        window.clearTimeout(deployPollTimer);
        deployPollTimer = null;
      }
    };

    const parseDotEnvText = (text) => {
      const out = [];
      const lines = String(text || "").split(/\r?\n/);
      for (const line of lines) {
        const t = line.trim();
        if (!t || t.startsWith("#")) continue;
        const eq = t.indexOf("=");
        if (eq <= 0) continue;
        const k = t.slice(0, eq).trim();
        let v = t.slice(eq + 1).trim();
        if (
          (v.startsWith('"') && v.endsWith('"')) ||
          (v.startsWith("'") && v.endsWith("'"))
        ) {
          v = v.slice(1, -1);
        }
        if (k) out.push({ key: k, value: v });
      }
      return out;
    };

    const collectEnvEntriesFromTable = () => {
      if (!(configureEnvTbody instanceof HTMLElement)) return [];
      const rows = configureEnvTbody.querySelectorAll("tr[data-config-env-row]");
      const list = [];
      rows.forEach((tr) => {
        const ki = tr.querySelector("[data-env-row-key]");
        const vi = tr.querySelector("[data-env-row-value]");
        if (ki instanceof HTMLInputElement && vi instanceof HTMLInputElement) {
          const key = ki.value.trim();
          const value = vi.value;
          if (key || value) list.push({ key, value });
        }
      });
      return list;
    };

    const renderConfigureEnvTable = () => {
      if (!(configureEnvTbody instanceof HTMLElement)) return;
      let rows = ensureEditableEnvRows(selectedRepo.envEntries);
      configureEnvTbody.innerHTML = "";
      rows.forEach((row, idx) => {
        const tr = document.createElement("tr");
        tr.className = "";
        tr.dataset.configEnvRow = "1";
        const inp =
          "font-sans w-full rounded-md border border-[#d9dbe3] bg-white px-2 py-1 text-xs text-[#111827] outline-none focus:border-[#bfc4d4]";
        tr.innerHTML = `
          <td class="pr-3 align-middle">
            <input type="text" data-env-row-key class="${inp}" value="" autocomplete="off" aria-label="Variable name" />
          </td>
          <td class="pr-2 align-middle">
            <input type="text" data-env-row-value class="${inp}" value="" autocomplete="off" aria-label="Value" />
          </td>
          <td class="w-8 shrink-0 align-middle text-center">
            <button type="button" data-env-row-remove class="inline-flex h-7 w-7 items-center justify-center rounded-md border-0 bg-transparent text-xs font-sans text-[#9ca3af] hover:text-[#111827]" aria-label="Remove row">×</button>
          </td>
        `;
        const kEl = tr.querySelector("[data-env-row-key]");
        const vEl = tr.querySelector("[data-env-row-value]");
        if (kEl instanceof HTMLInputElement) kEl.value = row.key || "";
        if (vEl instanceof HTMLInputElement) vEl.value = row.value || "";
        const rm = tr.querySelector("[data-env-row-remove]");
        if (rm instanceof HTMLElement) {
          rm.addEventListener("click", () => {
            selectedRepo.envEntries = ensureEditableEnvRows(
              collectEnvEntriesFromTable().filter((_, i) => i !== idx),
            );
            renderConfigureEnvTable();
          });
        }
        configureEnvTbody.appendChild(tr);
      });
    };

    const populateBranchSelect = (branches, preferredBranch) => {
      if (!(configureBranchSelect instanceof HTMLSelectElement)) return;
      const prev = String(preferredBranch || selectedRepo.branch || "").trim();
      configureBranchSelect.innerHTML = "";
      const list = Array.isArray(branches) ? branches : [];
      if (list.length === 0) {
        const opt = document.createElement("option");
        opt.value = prev || "main";
        opt.textContent = prev || "main";
        opt.selected = true;
        configureBranchSelect.appendChild(opt);
        configureBranchSelect.disabled = true;
        return;
      }
      configureBranchSelect.disabled = false;
      let matched = false;
      list.forEach((b) => {
        const name = String(b?.name || "").trim();
        if (!name) return;
        const opt = document.createElement("option");
        opt.value = name;
        opt.textContent = b.default ? `${name} (default)` : name;
        if (name === prev) {
          opt.selected = true;
          matched = true;
        }
        configureBranchSelect.appendChild(opt);
      });
      if (!matched && configureBranchSelect.options.length) {
        configureBranchSelect.options[0].selected = true;
        selectedRepo.branch = configureBranchSelect.value;
      }
    };

    const applyRepoHintsToSelected = (data) => {
      if (!data || data.ok !== true) return;
      selectedRepo.resolvedSha = typeof data.resolvedSha === "string" ? data.resolvedSha : "";
      const sig = Array.isArray(data.signals) ? data.signals : [];
      if (sig.includes("no-package-json") || sig.includes("invalid-package-json")) {
        return;
      }
      if (typeof data.preset === "string" && data.preset.trim()) {
        selectedRepo.preset = data.preset.trim();
      }
      if (typeof data.suggestedType === "string" && data.suggestedType.trim()) {
        selectedRepo.suggestedType = data.suggestedType.trim();
      }
      if (typeof data.suggestedBuild === "string" && data.suggestedBuild.trim()) {
        selectedRepo.build = data.suggestedBuild.trim();
      }
      if (typeof data.suggestedOutput === "string" && data.suggestedOutput.trim()) {
        selectedRepo.output = data.suggestedOutput.trim();
      }
    };

    const fetchRepoHintsForConfigure = async () => {
      if (!selectedRepo.full) return;
      const ref = String(selectedRepo.branch || "main").trim() || "main";
      const url = new URL("/api/workspace-vcs-repo-hints", window.location.href);
      url.searchParams.set("provider", activeProvider);
      url.searchParams.set("repo", selectedRepo.full);
      url.searchParams.set("ref", ref);
      setConfigureHintsLoading(true);
      try {
        const res = await fetch(url.toString(), { credentials: "include" });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) return;
        applyRepoHintsToSelected(data);
        syncRepoDataIntoViews();
      } catch {
        /* ignore */
      } finally {
        setConfigureHintsLoading(false);
      }
    };

    const scheduleConfigureHints = () => {
      window.clearTimeout(configureHintsTimer);
      configureHintsTimer = window.setTimeout(() => {
        void fetchRepoHintsForConfigure();
      }, 380);
    };

    const refreshConfigureVcsMetadata = async () => {
      if (!selectedRepo.full) return;
      const bUrl = new URL("/api/workspace-vcs-branches", window.location.href);
      bUrl.searchParams.set("provider", activeProvider);
      bUrl.searchParams.set("repo", selectedRepo.full);
      try {
        const res = await fetch(bUrl.toString(), { credentials: "include" });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.ok && Array.isArray(data.branches)) {
          populateBranchSelect(data.branches, selectedRepo.branch);
          selectedRepo.branch = configureBranchSelect.value || selectedRepo.branch;
        } else {
          populateBranchSelect([], selectedRepo.branch);
        }
      } catch {
        populateBranchSelect([], selectedRepo.branch);
      }
      await fetchRepoHintsForConfigure();
      syncRepoDataIntoViews();
    };

    const loadComposeDraftEnv = async () => {
      try {
        const res = await fetch("/api/workspace-compose-draft-env", { credentials: "include" });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.ok && Array.isArray(data.entries) && data.entries.length) {
          selectedRepo.envEntries = ensureEditableEnvRows(data.entries);
        } else {
          selectedRepo.envEntries = ensureEditableEnvRows([]);
        }
      } catch {
        selectedRepo.envEntries = ensureEditableEnvRows([]);
      }
      renderConfigureEnvTable();
    };

    const loadProjectConfigEnv = async (projectId) => {
      const pid = String(projectId || "").trim();
      if (!pid) return false;
      try {
        const url = new URL("/api/console-project-config", window.location.href);
        url.searchParams.set("id", pid);
        url.searchParams.set("environment", "prod");
        url.searchParams.set("reveal", "true");
        const res = await fetch(url.toString(), { credentials: "include" });
        const data = await res.json().catch(() => ({}));
        if (!res.ok || data.ok !== true || !Array.isArray(data.entries)) {
          return false;
        }
        selectedRepo.projectId = pid;
        selectedRepo.envEntries = ensureEditableEnvRows(data.entries);
        renderConfigureEnvTable();
        return true;
      } catch {
        return false;
      }
    };

    const loadConfigureEnvEntries = async () => {
      const knownProjectId =
        String(selectedRepo.projectId || "").trim() || resolveKnownProjectId();
      if (knownProjectId) {
        const loaded = await loadProjectConfigEnv(knownProjectId);
        if (loaded) return;
      }
      await loadComposeDraftEnv();
    };

    const saveComposeDraftEnv = async () => {
      selectedRepo.envEntries = collectEnvEntriesFromTable();
      const entries = selectedRepo.envEntries.filter((r) => r.key);
      try {
        const res = await fetch("/api/workspace-compose-draft-env", {
          method: "PUT",
          credentials: "include",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ entries }),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.ok) {
          /* silent persist before deploy */
        }
      } catch {
        /* ignore */
      }
    };

    const syncConfigureFormIntoSelectedRepo = () => {
      if (configureProjectName instanceof HTMLInputElement) {
        selectedRepo.name = configureProjectName.value.trim() || selectedRepo.name;
      }
      if (configureRoot instanceof HTMLInputElement) {
        selectedRepo.root = configureRoot.value.trim() || ".";
      }
      if (configureBuild instanceof HTMLInputElement) {
        selectedRepo.build = configureBuild.value;
      }
      if (configureOutput instanceof HTMLInputElement) {
        selectedRepo.output = configureOutput.value.trim() || "dist";
      }
      if (configureBranchSelect instanceof HTMLSelectElement) {
        selectedRepo.branch = configureBranchSelect.value || selectedRepo.branch;
      }
      selectedRepo.envEntries = collectEnvEntriesFromTable();
      const first = selectedRepo.envEntries[0];
      selectedRepo.envKey = first?.key || "";
      selectedRepo.envValue = first?.value || "";
    };

    const animateView = (node) => {
      if (!(node instanceof HTMLElement)) return;
      node.classList.remove("project-view-enter");
      requestAnimationFrame(() => {
        node.classList.add("project-view-enter");
      });
    };

    const isProviderImportConnected = (key) => {
      if (key === "github") return root.dataset.githubImportConnected === "true";
      if (key === "gitlab") return root.dataset.gitlabImportConnected === "true";
      if (key === "bitbucket") return root.dataset.bitbucketImportConnected === "true";
      if (key === "gitea") return root.dataset.giteaImportConnected === "true";
      return false;
    };

    const hasAnyVcsImportConnected = () =>
      IMPORT_PROVIDER_KEYS.some((key) => isProviderImportConnected(key));

    const syncConnectBackNav = () => {
      const el = root.querySelector("[data-project-connect-back]");
      if (!(el instanceof HTMLElement)) return;
      const on = root.dataset.connectBackFromImport === "true";
      el.classList.toggle("hidden", !on);
      el.setAttribute("aria-hidden", on ? "false" : "true");
    };

    const showView = (viewName) => {
      if (viewName === "import" && !hasAnyVcsImportConnected()) {
        root.dataset.connectBackFromImport = "";
        viewName = "connect";
      }
      if (viewName !== "deploying") {
        clearDeployPoll();
      }
      views.forEach((node) => {
        const active = node.dataset.projectView === viewName;
        node.classList.toggle("hidden", !active);
        if (node.dataset.projectView === "loading") {
          node.setAttribute("aria-busy", active ? "true" : "false");
        }

        if (active) {
          const shouldFlex = viewName === "connect" || viewName === "loading";
          node.classList.toggle("flex", shouldFlex);
          node.classList.remove("grid");
          animateView(node);
        } else {
          node.classList.remove("flex");
          node.classList.remove("grid");
        }
      });
      if (viewName === "import") {
        /** Macrotask (not microtask): `queueMicrotask` can run before inline listeners finish registering in some dev/build orders, so the event was dropped and `fetch` never ran. */
        window.setTimeout(() => {
          root.dispatchEvent(
            new CustomEvent("nz-vcs-import-open", {
              bubbles: true,
              detail: { provider: activeProvider },
            }),
          );
        }, 0);
      }
      syncConnectBackNav();
    };

    root.addEventListener("nz-project-show-connect", (e) => {
      root.dataset.connectBackFromImport = "";
      const detail = (e && e.detail) || {};
      const clearP = detail.clearProviderFromLinked;
      if (isImportProviderKey(clearP)) {
        const parts = String(root.dataset.linkedVcs || "")
          .split(",")
          .map((s) => s.trim())
          .filter(Boolean)
          .filter((p) => p !== clearP);
        root.dataset.linkedVcs = parts.join(",");
      }
      if (detail.clearGithubFromLinked) {
        const parts = String(root.dataset.linkedVcs || "")
          .split(",")
          .map((s) => s.trim())
          .filter(Boolean)
          .filter((p) => p !== "github");
        root.dataset.linkedVcs = parts.join(",");
      }
      /** Opt out of navigating to Connect (three provider buttons); used by rare multi-step flows. */
      if (detail.navigateToConnect === false) {
        return;
      }
      showView("connect");
    });

    const showProviderPanel = (providerKey) => {
      activeProvider = providerKey;
      providerPanels.forEach((panel) => {
        const match = panel.dataset.projectProviderPanel === providerKey;
        panel.classList.toggle("hidden", !match);
        panel.classList.toggle("grid", match);
      });
    };

    const setText = (node, value) => {
      if (node) node.textContent = value;
    };

    const setInputValue = (node, value) => {
      if (node instanceof HTMLInputElement) {
        node.value = value;
      }
    };

    const applyDeploySessionSnapshot = (snapshot) => {
      const provider = String(snapshot?.provider || "").trim();
      if (provider) activeProvider = provider;
      const repo = snapshot?.repo && typeof snapshot.repo === "object" ? snapshot.repo : {};
      selectedRepo = {
        ...selectedRepo,
        projectId: String(snapshot?.projectId || selectedRepo.projectId || "").trim(),
        name: String(repo.name || selectedRepo.name || "").trim(),
        full: String(repo.full || selectedRepo.full || "").trim(),
        branch: String(repo.branch || selectedRepo.branch || "main").trim() || "main",
        preset: String(repo.preset || selectedRepo.preset || "Other").trim() || "Other",
        root: String(repo.root || selectedRepo.root || ".").trim() || ".",
        build: String(repo.build || selectedRepo.build || "").trim(),
        output: String(repo.output || selectedRepo.output || "dist").trim() || "dist",
      };
    };

    const hydrateSelectedRepoFromDeployment = (deployment, project) => {
