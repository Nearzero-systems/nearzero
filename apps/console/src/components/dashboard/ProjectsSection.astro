            const res = await fetch("/api/console-deploy", {
              method: "POST",
              credentials: "include",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({
                provider: activeProvider,
                repoFull: full,
                branch: String(selectedRepo.branch || "main").trim() || "main",
                commit: String(selectedRepo.resolvedSha || "").trim(),
                projectId:
