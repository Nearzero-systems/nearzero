        if (deployedLogsWrap instanceof HTMLElement) deployedLogsWrap.classList.add("hidden");
        return;
      }
      deployedDeploymentId.textContent = `Deployment ID: ${sid}`;
      deployedDeploymentId.classList.remove("hidden");
      if (deployedLogsWrap instanceof HTMLElement && deployedLogsLink instanceof HTMLAnchorElement) {
        deployedLogsLink.href = `/app/deployments/${encodeURIComponent(sid)}`;
        deployedLogsWrap.classList.remove("hidden");
      }
    };

    const scheduleDeployPoll = (deploymentId) => {
      clearDeployPoll();
      persistDeploySession(deploymentId);
      const started = Date.now();
      const maxMs = 120000;
      let transientFailures = 0;
      const maxTransientPollFailures = 6;
      const tick = async () => {
        try {
          const res = await fetch(
            `/api/console-deployment?id=${encodeURIComponent(deploymentId)}`,
            { credentials: "include" },
          );
          const data = await res.json().catch(() => ({}));
          const dep = data.deployment;
          const project = data.project;
          if (!res.ok || !dep) {
            const retryable =
              res.status === 404 ||
              res.status === 502 ||
              res.status === 503 ||
              res.status === 504;
            if (retryable && transientFailures < maxTransientPollFailures) {
              transientFailures += 1;
              setDeployingStatus(
                `Syncing deployment status… (retry ${transientFailures}/${maxTransientPollFailures})`,
              );
              deployPollTimer = window.setTimeout(() => {
                void tick();
              }, 1200);
              return;
            }
            throw new Error(data.error || "Could not load deployment status");
          }
          transientFailures = 0;
          hydrateSelectedRepoFromDeployment(dep, project);
          const status = String(dep.status || "").trim();
          const url = String(
            dep.visitUrl || dep.defaultUrl || dep.serviceUrl || "",
          ).trim();
          if (status === "ready") {
            clearDeployPoll();
            clearDeploySession();
            setDeployingStatus(
              url ? "Deployment is live." : "Deployment finished.",
            );
            setText(deployedUrl, url || "—");
            setDeployedDeploymentMeta(deploymentId);
            showView("deployed");
            return;
          }
          if (status === "failed") {
            clearDeployPoll();
            clearDeploySession();
            nzToast("Deployment failed.");
            showView("configure");
            return;
          }
          const elapsed = Date.now() - started;
          let statusMsg = status
            ? `Status: ${status}…`
            : "Waiting for deployment status…";
          if (
            elapsed > 8000 &&
            (status === "queued" || status === "building" || !status)
          ) {
            statusMsg +=
              " Run the build worker in another terminal: bun run dev:worker (the deployer only runs after the build finishes).";
          } else if (elapsed > 8000 && status === "deploying") {
            statusMsg +=
              " Run the deployer in another terminal: bun run dev:deployer.";
          }
          setDeployingStatus(statusMsg);
          if (elapsed > maxMs) {
            clearDeployPoll();
            clearDeploySession();
            setText(deployedUrl, "—");
            setDeployedDeploymentMeta(deploymentId);
            nzToast(
              "Deployment is still in progress. Refresh the app or check the API for updates.",
            );
            showView("deployed");
            return;
          }
          deployPollTimer = window.setTimeout(() => {
            void tick();
          }, 2500);
        } catch (e) {
          clearDeployPoll();
          clearDeploySession();
          nzToast(
            String((e && e.message) || e || "").trim() ||
              "Could not track deployment.",
          );
          showView("configure");
        }
      };
      void tick();
    };

    const startDeployButtons = Array.from(
      root.querySelectorAll("[data-project-start-deploy]"),
