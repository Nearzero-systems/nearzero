    const syncConfigurePresetSelect = () => {
      if (!(configurePresetSelect instanceof HTMLSelectElement)) return;
      const pv = String(selectedRepo.preset || "Other").trim();
      let idx = -1;
      for (let i = 0; i < configurePresetSelect.options.length; i += 1) {
        if (configurePresetSelect.options[i].value === pv) {
          idx = i;
          break;
        }
      }
      if (idx < 0) {
        const pl = pv.toLowerCase();
        for (let i = 0; i < configurePresetSelect.options.length; i += 1) {
          const ov = configurePresetSelect.options[i].value.toLowerCase();
          if (ov === pl || (pl.includes("next") && ov.includes("next"))) {
            idx = i;
            break;
          }
        }
      }
      if (idx < 0) {
        for (let i = 0; i < configurePresetSelect.options.length; i += 1) {
          if (configurePresetSelect.options[i].value === "Other") {
            idx = i;
            break;
          }
        }
      }
      if (idx >= 0) configurePresetSelect.selectedIndex = idx;
      const v =
