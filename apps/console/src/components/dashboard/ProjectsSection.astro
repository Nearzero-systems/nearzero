      const getProviderMeta = (providerKey) =>
        providerOptions.find((provider) => provider.key === providerKey) || providerOptions[0];

      /** Colored brand icons for the import account dropdown (left of username). */
      const importAccountMenuIconHtml = (providerKey) => {
        if (providerKey === "github") {
          return `<span class="inline-flex shrink-0 text-[#24292f]" aria-hidden="true">${githubRepoRowIconSvg}</span>`;
        }
        const meta = getProviderMeta(providerKey);
        const accent = meta?.accent || "#111827";
        const d = meta?.iconPath || "";
        if (!d) return "";
        return `<svg class="h-[18px] w-[18px] shrink-0" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path fill="${accent}" d="${d}"/></svg>`;
      };

      const listConnectedImportProviders = () =>
        IMPORT_PROVIDER_KEYS.filter((key) => isProviderImportConnected(key));

      const getAccounts = () => accountData[activeProvider] || [];

      const getActiveAccount = () =>
        getAccounts().find((item) => item.key === activeAccount) || getAccounts()[0];

      const ensureAccount = () => {
        const current = getActiveAccount();
        if (current) activeAccount = current.key;
        return current;
      };

      const applyImportToolbarProviderChrome = (providerKey) => {
        const providerMeta = getProviderMeta(providerKey);
        if (accountIcon instanceof SVGElement) {
          accountIcon.style.color = providerMeta?.accent || "#24292f";
        }
        if (accountIconPath instanceof SVGPathElement) {
          accountIconPath.setAttribute("d", providerMeta?.iconPath || "");
        }
      };

      const closeAccountMenu = () => {
        if (accountDetails instanceof HTMLDetailsElement) accountDetails.open = false;
        if (summaryEl instanceof HTMLElement) summaryEl.setAttribute("aria-expanded", "false");
      };

      const getAllImportAccountRows = () => {
        const rows = [];
        for (const providerKey of IMPORT_PROVIDER_KEYS) {
          if (!isProviderImportConnected(providerKey)) continue;
          const accounts = accountData[providerKey] || [];
          for (const account of accounts) {
            rows.push({ providerKey, account });
          }
        }
        return rows;
      };

      const renderAccounts = () => {
        if (!(accountItems instanceof HTMLElement)) return;
        accountItems.innerHTML = "";

        const rows = getAllImportAccountRows();
        rows.forEach(({ providerKey, account }) => {
          const button = document.createElement("button");
          button.type = "button";
          button.className =
            "font-sans flex w-full items-center justify-between gap-2 rounded-md px-2 py-1.5 text-left text-xs transition-colors hover:bg-[#f7f7f8]";
          const labelSafe = escapeHtml(account.label);
          const isActive = providerKey === activeProvider && account.key === activeAccount;
          button.innerHTML = `
            <span class="flex min-w-0 flex-1 items-center gap-2.5">
              ${importAccountMenuIconHtml(providerKey)}
              <span class="truncate text-[#111827]">${labelSafe}</span>
            </span>
            <span class="${isActive ? "text-[#111827]" : "text-transparent"} shrink-0">✓</span>
          `;
          button.addEventListener("click", () => {
            activeProvider = providerKey;
            activeAccount = account.key;
            applyImportToolbarProviderChrome(providerKey);
            if (labelNode) labelNode.textContent = account.label;
            renderAccounts();
            renderRepos();
            closeAccountMenu();
          });
          accountItems.appendChild(button);
        });
      };

      const renderRepos = () => {
        if (!(repoList instanceof HTMLElement)) return;

        const account = ensureAccount();
        if (!account) {
          if (
            isImportProviderKey(activeProvider)
          ) {
            if (!isProviderImportConnected(activeProvider)) {
              root.dispatchEvent(
                new CustomEvent("nz-project-show-connect", { bubbles: true, detail: {} }),
              );
              return;
            }
            repoList.innerHTML = getLoadingSpinnerHtml();
          }
          return;
        }
        const rowProto =
          template instanceof HTMLTemplateElement
            ? template.content.firstElementChild
            : template instanceof HTMLElement
              ? template.firstElementChild
              : null;
        if (!(rowProto instanceof HTMLElement)) {
          repoList.innerHTML =
            '<div class="px-4 py-6 text-sm text-[#9f3131]">Repository list UI failed to load. Refresh the page.</div>';
          return;
        }

        applyImportToolbarProviderChrome(activeProvider);
        if (labelNode) labelNode.textContent = account.label;

        repoList.innerHTML = "";
        const repoSource = Array.isArray(account.repos) ? account.repos : [];
        const repos = repoSource.filter((repo) => {
          if (!searchValue) return true;
          return (
            repo.name.toLowerCase().includes(searchValue) ||
            repo.repo.toLowerCase().includes(searchValue)
          );
        });

        if (repos.length === 0) {
          const emptyCopy = searchValue
            ? "No repositories match this search."
            : "No repositories found for this account.";
          repoList.innerHTML = `<div class="px-4 py-6 text-sm text-[#6b7280]">${emptyCopy}</div>`;
          return;
        }

        repos.forEach((repo) => {
          const fragment = rowProto.cloneNode(true);
          if (!(fragment instanceof HTMLElement)) return;

          const icon = fragment.querySelector("[data-row-icon]");
          const name = fragment.querySelector("[data-row-name]");
          const meta = fragment.querySelector("[data-row-meta]");
          const action = fragment.querySelector("[data-project-repo-select]");

          if (icon instanceof HTMLElement) {
            if (activeProvider === "github") {
              icon.className = "flex items-center justify-center text-[#24292f]";
              icon.innerHTML = githubRepoRowIconSvg;
            } else {
              icon.className = "text-xs font-medium text-[#111827]";
              icon.textContent = providerIconMap[activeProvider] || "GH";
            }
          }
          if (name) name.textContent = repo.name;
          if (meta) {
            const stack = String(repo.stackLabel || "").trim();
            meta.textContent = stack
              ? `${stack} · ${repo.visibility} · ${repo.updatedLabel}`
              : `${repo.visibility} · ${repo.updatedLabel}`;
          }

          if (action instanceof HTMLElement) {
            action.dataset.providerKey = activeProvider;
            action.dataset.providerLabel = providerLabelMap[activeProvider] || "GitHub";
            action.dataset.repoKey = repo.key;
            action.dataset.repoName = repo.name;
            action.dataset.repoFull = repo.repo;
            action.dataset.repoBranch = repo.branch;
            action.dataset.repoPreset = repo.preset;
            action.dataset.repoRoot = repo.rootDirectory;
            action.dataset.repoBuild = repo.buildCommand;
            action.dataset.repoOutput = repo.outputDirectory;
            action.dataset.repoEnvKey = repo.envKey;
            action.dataset.repoEnvValue = repo.envValue;
          }

          repoList.appendChild(fragment);
        });
      };

      const setProvider = (providerKey) => {
        if (
          isImportProviderKey(providerKey) &&
          !isProviderImportConnected(providerKey)
        ) {
          root.dispatchEvent(
            new CustomEvent("nz-project-show-connect", { bubbles: true, detail: {} }),
          );
          return;
        }
        void loadAllConnectedImportRepos({ preferredProvider: providerKey });
      };

      if (accountDetails instanceof HTMLDetailsElement && summaryEl instanceof HTMLElement) {
        accountDetails.addEventListener("toggle", () => {
          summaryEl.setAttribute("aria-expanded", accountDetails.open ? "true" : "false");
        });
      }

      document.addEventListener("click", (event) => {
        if (!(accountDetails instanceof HTMLDetailsElement)) return;
        const n = event.target;
        if (n instanceof Node && accountDetails.contains(n)) return;
        accountDetails.open = false;
        summaryEl?.setAttribute("aria-expanded", "false");
      });

      if (searchInput instanceof HTMLInputElement) {
        searchInput.addEventListener("input", () => {
          searchValue = searchInput.value.trim().toLowerCase();
          renderRepos();
        });
      }

      shell.addEventListener("click", (event) => {
        const el = event.target;
        if (!(el instanceof Element)) return;
        if (el.closest("[data-project-account-details] summary")) return;
        const addAccount = el.closest("[data-project-account-add]");
        if (addAccount instanceof HTMLElement) {
          closeAccountMenu();
          root.dataset.connectBackFromImport = "true";
          showView("connect");
          return;
        }
      });

      let importReposLoadPromise = null;
      /** Providers whose repo lists were loaded successfully this session (avoids refetch on every return to import). */
      const importReposFetchedProviders = new Set();
      /** Skip refetch after a reconnect toast until user re-links (avoids 401 spam while other providers work). */
      const importReposSkipUntilRelink = new Set();

      const providerImportCacheWarm = (p) => {
        const rows = accountData[p];
        return (
          importReposFetchedProviders.has(p) &&
          Array.isArray(rows) &&
          rows.length > 0
        );
      };

      /**
       * Fetches repo lists for one VCS provider. Returns "reconnect" if the user must re-auth,
       * "ok" if accounts were stored, otherwise "fail".
       */
      async function fetchProviderReposAccounts(fetchingProvider) {
        const repoApiUrl = new URL(
          `/api/workspace-vcs-repos?provider=${encodeURIComponent(fetchingProvider)}`,
          window.location.href,
        ).toString();
        const clientTimeoutMs = 60_000;
        try {
          const res = await fetch(repoApiUrl, {
            credentials: "include",
            signal: repoFetchAbortSignal(clientTimeoutMs),
          });
          const data = await res.json().catch(() => ({}));

          const importView = root.querySelector('[data-project-view="import"]');
          const importVisible =
            importView instanceof HTMLElement && !importView.classList.contains("hidden");

          if (!res.ok) {
            const errMsg = data?.error || "Could not load repositories.";
            const code = data?.code;
            const errStr = String(errMsg);
            const needsReconnectGithub =
              fetchingProvider === "github" &&
              (code === "VCS_GITHUB_TOKEN_EXPIRED" ||
                code === "VCS_GITHUB_DECRYPT_FAILED" ||
                res.status === 401 ||
                /not connected|expired|revoked|connect github|could not be decrypted|decrypt/i.test(
                  errStr,
                ));
            const needsReconnectGitlab =
              fetchingProvider === "gitlab" &&
              (code === "VCS_GITLAB_TOKEN_EXPIRED" ||
                code === "VCS_GITLAB_DECRYPT_FAILED" ||
                res.status === 401 ||
                /connect gitlab|gitlab is not connected|could not be decrypted|decrypt/i.test(
                  errStr,
                ));
            const needsReconnectBitbucket =
              fetchingProvider === "bitbucket" &&
              (code === "VCS_BITBUCKET_TOKEN_EXPIRED" ||
                code === "VCS_BITBUCKET_DECRYPT_FAILED" ||
                res.status === 401 ||
                /connect bitbucket|bitbucket is not connected|could not be decrypted|decrypt/i.test(
                  errStr,
                ));
            const needsReconnectGitea =
              fetchingProvider === "gitea" &&
              (code === "VCS_GITEA_TOKEN_EXPIRED" ||
                code === "VCS_GITEA_DECRYPT_FAILED" ||
                res.status === 401 ||
                /connect gitea|gitea is not connected|could not be decrypted|decrypt/i.test(
                  errStr,
                ));
            if (
              needsReconnectGithub ||
              needsReconnectGitlab ||
              needsReconnectBitbucket ||
              needsReconnectGitea
            ) {
              const label = providerLabelFallback(fetchingProvider);
              nzToast(`Your ${label} connection needs a refresh. Connect again to continue.`);
              importReposSkipUntilRelink.add(fetchingProvider);
              delete accountData[fetchingProvider];
              importReposFetchedProviders.delete(fetchingProvider);
              const clearGithubFromLinked =
                fetchingProvider === "github" &&
                (code === "VCS_GITHUB_TOKEN_EXPIRED" ||
                  code === "VCS_GITHUB_DECRYPT_FAILED" ||
                  (res.status === 400 &&
                    /not connected for this account|github is not connected|connect github/i.test(
                      errStr,
                    )));
              root.dispatchEvent(
                new CustomEvent("nz-project-show-connect", {
                  bubbles: true,
                  detail: clearGithubFromLinked
                    ? { clearGithubFromLinked }
                    : { clearProviderFromLinked: fetchingProvider },
                }),
              );
              return "reconnect";
            }
            if (importVisible) {
              nzToast(repoLoadToastForHttp(errMsg, res.status));
            }
            return "fail";
          }
          if (data.provider === fetchingProvider && Array.isArray(data.accounts)) {
            if (data.accounts.length > 0) {
              accountData[fetchingProvider] = data.accounts;
            } else {
              const pl = providerLabelFallback(fetchingProvider);
              accountData[fetchingProvider] = [
                {
                  key: `${fetchingProvider}-linked`,
                  label: pl,
                  repos: [],
                },
              ];
            }
            importReposFetchedProviders.add(fetchingProvider);
            return "ok";
          }
          return "fail";
        } catch (err) {
          const importView = root.querySelector('[data-project-view="import"]');
          const importVisible =
            importView instanceof HTMLElement && !importView.classList.contains("hidden");
          if (importVisible) {
            const name = err && err.name;
            const timedOut = name === "TimeoutError" || name === "AbortError";
            nzToast(
              timedOut
                ? "Request timed out. Check that the API is running and try again."
                : "Network error. Try again.",
            );
          }
          return "fail";
        }
      }

      function softRefreshImportReposUi() {
        const importView = root.querySelector('[data-project-view="import"]');
        const importVisible =
          importView instanceof HTMLElement && !importView.classList.contains("hidden");
        applyImportToolbarProviderChrome(activeProvider);
        renderAccounts();
        if (importVisible) renderRepos();
        setImportToolbarVisible(true);
      }

      /**
       * Loads repository lists for every connected import provider so the account menu can list
       * GitHub, GitLab, and Bitbucket accounts together.
       */
      function loadAllConnectedImportRepos(opts) {
        const preferredRaw =
          opts && opts.preferredProvider && typeof opts.preferredProvider === "string"
            ? opts.preferredProvider.trim()
            : "";
        const preferred =
          isImportProviderKey(preferredRaw)
            ? preferredRaw
            : activeProvider;

        if (!(repoList instanceof HTMLElement)) {
          return Promise.resolve();
        }

        const connected = listConnectedImportProviders();
        if (!connected.length) {
          root.dispatchEvent(
            new CustomEvent("nz-project-show-connect", { bubbles: true, detail: {} }),
          );
          return Promise.resolve();
        }

        if (importReposLoadPromise) {
          return importReposLoadPromise;
        }

        const allProvidersAlreadyFetched =
          connected.length > 0 && connected.every((p) => providerImportCacheWarm(p));

        if (allProvidersAlreadyFetched) {
          softRefreshImportReposUi();
          return Promise.resolve();
        }

        setImportToolbarVisible(false);
        repoList.innerHTML = getLoadingSpinnerHtml();

        importReposLoadPromise = (async () => {
          try {
            const prevProvider = activeProvider;
            const prevAccount = activeAccount;
            let sawOk = false;
            let sawFail = false;
            for (const p of connected) {
              if (importReposSkipUntilRelink.has(p)) {
                continue;
              }
              if (providerImportCacheWarm(p)) {
                sawOk = true;
                continue;
              }
              const outcome = await fetchProviderReposAccounts(p);
              if (outcome === "reconnect") {
                sawFail = true;
                continue;
              }
              if (outcome === "ok") sawOk = true;
              if (outcome === "fail") sawFail = true;
            }

            const importView = root.querySelector('[data-project-view="import"]');
            const importVisible =
              importView instanceof HTMLElement && !importView.classList.contains("hidden");

            const accountsFor = (p) => accountData[p] || [];

            const pickProvider = () => {
              if (
                isImportProviderKey(prevProvider) &&
                isProviderImportConnected(prevProvider) &&
                accountsFor(prevProvider).some((a) => a.key === prevAccount)
              ) {
                return prevProvider;
              }
              if (
                isImportProviderKey(preferred) &&
                isProviderImportConnected(preferred) &&
                accountsFor(preferred).length
              ) {
                return preferred;
              }
              for (const p of IMPORT_PROVIDER_KEYS) {
                if (isProviderImportConnected(p) && accountsFor(p).length) {
                  return p;
                }
              }
              return null;
            };

            const picked = pickProvider();
            if (!picked) {
              if (importVisible) {
                repoList.innerHTML =
                  sawFail && !sawOk
                    ? repoListLoadFailedHtml()
                    : '<div class="px-4 py-6 text-sm text-[#6b7280]">No repositories returned.</div>';
              }
              return;
            }

            activeProvider = picked;
            const list = accountsFor(picked);
            const keep =
              prevProvider === picked && list.some((a) => a.key === prevAccount)
                ? list.find((a) => a.key === prevAccount)
                : list[0];
            if (keep?.key) activeAccount = keep.key;
            applyImportToolbarProviderChrome(activeProvider);
            if (labelNode && keep?.label) {
              labelNode.textContent = keep.label;
            }

            renderAccounts();
            if (importVisible) {
              renderRepos();
            }
          } finally {
            importReposLoadPromise = null;
            setImportToolbarVisible(true);
          }
        })();

        return importReposLoadPromise;
      }

      root?.addEventListener("nz-vcs-link-updated", (e) => {
        const p = (e && e.detail && e.detail.provider) || activeProvider;
        const pk = String(p || "github").trim() || "github";
        if (isImportProviderKey(pk)) {
          delete accountData[pk];
          importReposFetchedProviders.delete(pk);
          importReposSkipUntilRelink.delete(pk);
        }
        setProvider(pk);
      });

      root.addEventListener("nz-vcs-import-open", (event) => {
        const d = event && event.detail;
        const providerKey = String(d?.provider || "github").trim() || "github";
        setProvider(providerKey);
      });

      const bootstrapImportIfVisible = () => {
        const importEl = root.querySelector('[data-project-view="import"]');
        if (!(importEl instanceof HTMLElement)) {
          return;
        }
        if (importEl.classList.contains("hidden")) {
          return;
        }
        if (!hasAnyVcsImportConnected()) {
          root.dispatchEvent(
            new CustomEvent("nz-project-show-connect", { bubbles: true, detail: {} }),
          );
          return;
        }
        const preferred =
          isImportProviderKey(activeProvider) && isProviderImportConnected(activeProvider)
            ? activeProvider
            : listConnectedImportProviders()[0] || "github";
        void loadAllConnectedImportRepos({ preferredProvider: preferred });
      };

      const importPanel = root.querySelector('[data-project-view="import"]');
      if (importPanel instanceof HTMLElement) {
        const hadHiddenClass = (classAttr) =>
          /(?:^|\s)hidden(?:\s|$)/.test(String(classAttr || ""));
        const mo = new MutationObserver((mutations) => {
          let becameVisible = false;
          for (const m of mutations) {
            if (m.type !== "attributes" || m.attributeName !== "class") continue;
            if (m.target !== importPanel) continue;
            const wasHidden = hadHiddenClass(m.oldValue);
            const nowHidden = importPanel.classList.contains("hidden");
            if (wasHidden && !nowHidden) becameVisible = true;
          }
          if (!becameVisible) return;
          if (!hasAnyVcsImportConnected()) {
            root.dispatchEvent(
              new CustomEvent("nz-project-show-connect", { bubbles: true, detail: {} }),
            );
            return;
          }
          const preferred =
            isImportProviderKey(activeProvider) && isProviderImportConnected(activeProvider)
              ? activeProvider
              : listConnectedImportProviders()[0] || "github";
          void loadAllConnectedImportRepos({ preferredProvider: preferred });
        });
        mo.observe(importPanel, {
          attributes: true,
          attributeFilter: ["class"],
          attributeOldValue: true,
        });
      }

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          bootstrapImportIfVisible();
        });
      });
      window.setTimeout(bootstrapImportIfVisible, 0);
      window.setTimeout(bootstrapImportIfVisible, 400);

      document.addEventListener("astro:page-load", () => {
        window.setTimeout(bootstrapImportIfVisible, 0);
      });

      function forceLiveRepoFetchIfImportVisible() {
        const imp = root.querySelector('[data-project-view="import"]');
        if (!(imp instanceof HTMLElement) || imp.classList.contains("hidden")) return;
        if (!hasAnyVcsImportConnected()) return;
        const preferred =
          isImportProviderKey(activeProvider) &&
          isProviderImportConnected(activeProvider)
            ? activeProvider
            : listConnectedImportProviders()[0] || "github";
        void loadAllConnectedImportRepos({ preferredProvider: preferred });
      }
      window.setTimeout(forceLiveRepoFetchIfImportVisible, 0);
      window.setTimeout(forceLiveRepoFetchIfImportVisible, 100);
      document.addEventListener("astro:after-swap", () => {
        window.setTimeout(forceLiveRepoFetchIfImportVisible, 0);
      });

      consumeVcsOAuthReturnIfPresent = () => {
        try {
          const url = new URL(window.location.href);
          const ret = String(url.searchParams.get("nz_vcs_return") || "")
            .trim()
            .toLowerCase();
          if (!isImportProviderKey(ret)) {
            return false;
          }
          url.searchParams.delete("nz_vcs_return");
          const next = `${url.pathname}${url.search}${url.hash}`;
          window.history.replaceState({}, "", next || url.pathname);

          importReposSkipUntilRelink.delete(ret);
          delete accountData[ret];
          importReposFetchedProviders.delete(ret);

          root.dataset[`${ret}ImportConnected`] = "true";
          const linkedParts = String(root.dataset.linkedVcs || "")
            .split(",")
            .map((s) => s.trim())
            .filter(Boolean);
          if (!linkedParts.includes(ret)) {
            linkedParts.push(ret);
            root.dataset.linkedVcs = linkedParts.join(",");
          }

          activeProvider = ret;
          showProviderPanel(ret);
          showView("import");
          void loadAllConnectedImportRepos({ preferredProvider: ret });
          return true;
        } catch {
          return false;
        }
      };
    })();

    const linked = String(root.dataset.linkedVcs || "")
      .split(",")
      .map((s) => s.trim())
      .filter(Boolean);
    const hasLinkedVcs = linked.length > 0;
    const initialRaw = String(root.dataset.initialView || "").trim();
    let initial = "connect";
    if (initialRaw === "connect" || initialRaw === "import" || initialRaw === "inventory") {
      initial = initialRaw;
    } else {
      const hasProjects = root.dataset.hasProjects === "true";
      if (hasProjects) initial = "inventory";
      else if (hasAnyVcsImportConnected()) initial = "import";
    }

    const resumeDeploySessionIfPresent = () => {
      try {
        const raw = sessionStorage.getItem(NZ_DEPLOY_SESSION_KEY);
        if (!raw) return false;
        const o = JSON.parse(raw);
        const depId = String(o.deploymentId || "").trim();
        const startedAt = Number(o.startedAt) || 0;
        if (!depId) {
          clearDeploySession();
          return false;
        }
        if (Date.now() - startedAt > 86400000) {
          clearDeploySession();
          return false;
        }
        applyDeploySessionSnapshot(o);
        syncRepoDataIntoViews();
        showDeploymentIdLine(depId);
        setDeployingStatus("Resuming deployment status…");
        showView("deploying");
        scheduleDeployPoll(depId);
        return true;
      } catch {
        clearDeploySession();
        return false;
      }
    };

    if (!resumeDeploySessionIfPresent()) {
      if (!consumeVcsOAuthReturnIfPresent()) {
        showView(initial);
      }
    }
    if (hasLinkedVcs && linked.includes(activeProvider) === false) {
      activeProvider = linked[0] || "github";
    }
    showProviderPanel(activeProvider);
    syncRepoDataIntoViews();
  })();
</script>

<style>
  .project-view-enter {
    animation: project-view-enter 0.28s ease both;
  }

  @keyframes project-view-enter {
    0% {
      opacity: 0;
      filter: blur(10px);
      transform: translateY(8px);
    }
    100% {
      opacity: 1;
      filter: blur(0);
      transform: translateY(0);
    }
  }
</style>
