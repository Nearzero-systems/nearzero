      const output = String(
        dep?.spec?.build?.output ||
          dep?.spec?.assets?.publicDir ||
          selectedRepo.output ||
          "dist",
      ).trim() || "dist";
      selectedRepo = {
        ...selectedRepo,
        projectId: String(proj.id || selectedRepo.projectId || "").trim(),
        name: String(proj.name || dep.name || selectedRepo.name || "").trim(),
        full: String(repo.repo || selectedRepo.full || "").trim(),
        branch: String(repo.branch || selectedRepo.branch || "main").trim() || "main",
        preset: framework,
        root: String(dep?.spec?.root || selectedRepo.root || ".").trim() || ".",
