---
import NearzeroLanding from "@/components/marketing/NearzeroLanding.astro";
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import { NEARZERO_DOCS_URL } from "@/lib/branding";

const title = "Nearzero - Launch apps on your own server";
const description =
	"Nearzero helps you deploy apps, connect domains, run databases and backups, watch logs, and use an infrastructure Agent on your own server.";
const canonicalUrl = "https://nearzero.dev/";
const githubUrl = "https://github.com/Nearzero-systems/nearzero";

const jsonLd = [
	{
		"@context": "https://schema.org",
		"@type": "Organization",
		name: "Nearzero",
		url: canonicalUrl,
		logo: `${canonicalUrl}logo.svg`,
		sameAs: [githubUrl],
	},
	{
		"@context": "https://schema.org",
		"@type": "SoftwareApplication",
		name: "Nearzero",
		applicationCategory: "DeveloperApplication",
		operatingSystem: "Linux",
		description,
		url: canonicalUrl,
		codeRepository: githubUrl,
		softwareHelp: NEARZERO_DOCS_URL,
		offers: {
			"@type": "Offer",
			price: "0",
			priceCurrency: "USD",
		},
	},
];
---
<MarketingLayout
	title={title}
	description={description}
	canonicalUrl={canonicalUrl}
	ogImage="/logo.svg"
	jsonLd={jsonLd}
>
	<NearzeroLanding />
</MarketingLayout>
