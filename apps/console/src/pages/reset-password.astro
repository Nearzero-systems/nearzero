---
import Base from "@/layouts/Base.astro";
import ResetPasswordGrid from "@/components/auth/ResetPasswordGrid.astro";
import { pageTitle } from "@/lib/branding";
import { getSession } from "@/lib/backendProxy";

const token = Astro.url.searchParams.get("token") ?? "";
const error = Astro.url.searchParams.get("error") ?? "";

const session = await getSession(Astro.request);
if (session?.user) {
	return Astro.redirect("/dashboard/agent");
}
---
<Base title={pageTitle("Reset password")}>
	<ResetPasswordGrid token={token} error={error} />
</Base>
