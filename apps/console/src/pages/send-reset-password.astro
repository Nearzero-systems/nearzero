---
import Base from "@/layouts/Base.astro";
import SendResetPasswordGrid from "@/components/auth/SendResetPasswordGrid.astro";
import { pageTitle } from "@/lib/branding";
import { getSession } from "@/lib/backendProxy";

const session = await getSession(Astro.request);
if (session?.user) {
	return Astro.redirect("/dashboard/agent");
}
---
<Base title={pageTitle("Reset password")}>
	<SendResetPasswordGrid />
</Base>
