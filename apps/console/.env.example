# =============================================================================
# Nearzero Console (@nearzero/console) — environment variables
# =============================================================================
# Copy to `.env` for local dev, or set the same keys in Vercel / your host.
#
# Astro/Vite: `PUBLIC_*` vars are exposed to the browser. Others are server-only.
# The console proxies API/auth/tRPC to the platform via BACKEND_URL.
#
# Platform must also be configured (separate apps/platform/.env):
#   CONSOLE_URL              = this console’s public URL
#   BETTER_AUTH_URL          = same as BACKEND_URL (platform API)
#   PUBLIC_GIT_PROVIDER_BASE_URL = same as below (for Git OAuth/webhooks)
# =============================================================================

# --- Required: platform API (server-side BFF proxy) ---------------------------

# Primary upstream for /api/*, auth, tRPC, deploy webhooks, etc.
BACKEND_URL=http://127.0.0.1:3000

# Fallback for BACKEND_URL; used in some UI (e.g. Git providers). Set same in prod.
PUBLIC_BACKEND_URL=http://127.0.0.1:3000

# --- Strongly recommended: public console URL (Git OAuth / GitHub App) --------

# HTTPS URL users hit for the console. Required for GitHub App manifest / callbacks.
# Localhost does not work for GitHub App setup — use a tunnel or deployed domain.
PUBLIC_GIT_PROVIDER_BASE_URL=https://app.nearzero.dev

# --- Optional: branding links (footer / about) --------------------------------

PUBLIC_NEARZERO_DOCS_URL=https://docs.nearzero.dev
PUBLIC_NEARZERO_GITHUB_URL=#
PUBLIC_NEARZERO_SUPPORT_URL=mailto:support@nearzero.dev
PUBLIC_NEARZERO_ISSUES_URL=#

# --- Optional: monitoring charts ------------------------------------------------

# External metrics API (see Monitoring dashboard)
PUBLIC_METRICS_URL=
PUBLIC_METRICS_TOKEN=

# --- Optional: agent dashboard copy (server-only) -------------------------------
# Omit both to keep defaults:
#   NEARZERO_AGENT_GREETING_TITLE="Hi {firstName}, what should we work on today?"
#   NEARZERO_AGENT_GREETING_SUBTITLE="Your deployment assistant for projects, logs, and infrastructure."

# --- Dev / scripts only (not required for deploy) -------------------------------

# Used by scripts/verify-redirects.ts
# CONSOLE_URL=http://localhost:4321

# =============================================================================
# Production (Vercel) — see .env.production
# =============================================================================
# Console: https://app.nearzero.dev
# BACKEND_URL=https://api.nearzero.dev
# PUBLIC_GIT_PROVIDER_BASE_URL=https://app.nearzero.dev
# Agent greeting: leave NEARZERO_AGENT_GREETING_* unset (built-in copy)
